---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";
---

<MainLayout title="Airsoft Nation | Centro táctico especializado">

  <Hero />

  <section class="hub">

    <!-- TIENDA -->
    <section class="hub-card primary">
      <h2>
        <i class="bi bi-shop"></i>
        <span>Tienda Física · Celrà</span>
      </h2>

      <p class="address">
        C. Just Puig, local 14 · 17460 Celrà (Girona)
      </p>

      <p class="card-text">
        Asesoramiento técnico especializado, comunidad activa y atención profesional.
      </p>

      <div class="hub-actions">
        <a href="https://maps.app.goo.gl/qZ9mKjF6iWpGxFBG7"
           target="_blank"
           class="btn-primary">
          <i class="bi bi-geo-alt"></i>
          Cómo llegar
        </a>

        <a href="/contacto-form/" class="btn-secondary">
          <i class="bi bi-envelope"></i>
          Contactar
        </a>
      </div>
    </section>

    <!-- HPA -->
    <section class="hub-card">
      <h2>
        <i class="bi bi-gear"></i>
        <span>Centro Técnico HPA</span>
      </h2>

      <p class="card-text">
        Instalación, configuración y optimización avanzada de sistemas HPA.
      </p>

      <div class="hub-actions">
        <a href="/hpa/" class="btn-primary">
          <i class="bi bi-tools"></i>
          Servicio HPA
        </a>

        <a href="/taller/" class="btn-secondary">
          <i class="bi bi-wrench"></i>
          Taller general
        </a>
      </div>
    </section>

    <!-- WOLVERINE -->
    <section class="hub-card highlight">
      <h2>
        <i class="bi bi-lightning-charge"></i>
        <span>Wolverine Systems</span>
      </h2>

      <p class="card-text">
        Sistemas HPA premium, configuraciones avanzadas y builds optimizadas.
      </p>

      <div class="hub-actions single">
        <a href="/wolverine/" class="btn-primary full">
          <i class="bi bi-arrow-right-circle"></i>
          Ver sistemas
        </a>
      </div>
    </section>

    <!-- GRID -->
    <section class="hub-grid">

      <a href="/comprar/" class="mini-card">
        <i class="bi bi-bag"></i>
        <div>
          <h3>Comprar</h3>
          <span>Catálogo online</span>
        </div>
      </a>

      <a href="/eventos/" class="mini-card">
        <i class="bi bi-trophy"></i>
        <div>
          <h3>Eventos</h3>
          <span>Competiciones</span>
        </div>
      </a>

      <a href="/ir-a-jugar/" class="mini-card">
        <i class="bi bi-flag"></i>
        <div>
          <h3>Ir a jugar</h3>
          <span>Campos recomendados</span>
        </div>
      </a>

      <a href="/novedades/" class="mini-card">
        <i class="bi bi-megaphone"></i>
        <div>
          <h3>Novedades</h3>
          <span>Últimos lanzamientos</span>
        </div>
      </a>

      <a href="/saber/" class="mini-card">
        <i class="bi bi-journal-text"></i>
        <div>
          <h3>Saber</h3>
          <span>Blog y FAQs</span>
        </div>
      </a>

    </section>

  </section>

</MainLayout>

<style>
.hub {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

/* CARDS PRINCIPALES */
.hub-card {
  padding: 18px;
  border-radius: var(--radius);
  background: var(--bg-card);
  box-shadow: var(--shadow-card);
}

.hub-card.primary {
  border: 1px solid var(--primary);
}

.hub-card.highlight {
  border: 1px solid rgba(225,6,0,0.4);
}

.hub-card h2 {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: "Oswald", sans-serif;
  font-size: 1.15rem;
  margin: 0 0 8px;
}

.hub-card h2 i {
  font-size: 1.1rem;
  color: var(--primary);
}

.address {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.card-text {
  font-size: 0.9rem;
  margin-bottom: 14px;
  color: var(--text-muted);
}

.hub-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.hub-actions.single .full {
  width: 100%;
  justify-content: center;
}

/* BOTONES */
.btn-primary,
.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  font-size: 0.85rem;
}

/* GRID APP */
.hub-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.mini-card {
  display: flex;
  gap: 12px;
  padding: 16px;
  border-radius: var(--radius);
  background: var(--bg-card);
  text-decoration: none;
  color: var(--text-main);
  box-shadow: var(--shadow-card);
  align-items: center;
}

.mini-card i {
  font-size: 1.2rem;
  color: var(--primary);
}

.mini-card h3 {
  margin: 0;
  font-size: 0.9rem;
  font-weight: 600;
}

.mini-card span {
  font-size: 0.75rem;
  color: var(--text-muted);
}
</style>
