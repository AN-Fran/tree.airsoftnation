---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";
---

<MainLayout title="Airsoft Nation | Centro táctico especializado">

  <Hero />

  <section class="hub">

    <!-- TIENDA -->
    <section class="hub-card primary">
      <h2>
        <span class="icon">🏬</span>
        Tienda Física · Celrà
      </h2>

      <p class="address">
        C. Just Puig, local 14 · 17460 Celrà (Girona)
      </p>

      <p>
        Asesoramiento técnico especializado, comunidad activa y atención profesional.
      </p>

      <div class="hub-actions">
        <a href="https://maps.app.goo.gl/qZ9mKjF6iWpGxFBG7"
           target="_blank"
           class="btn-main">
          Cómo llegar
        </a>

        <a href="/contacto-form/" class="btn-secondary">
          Contactar
        </a>
      </div>
    </section>

    <!-- HPA -->
    <section class="hub-card">
      <h2>
        <span class="icon">🔧</span>
        Centro Técnico HPA
      </h2>

      <p>
        Instalación, configuración y optimización avanzada de sistemas HPA.
      </p>

      <div class="hub-actions">
        <a href="/hpa/" class="btn-main">
          Servicio HPA
        </a>

        <a href="/taller/" class="btn-secondary">
          Taller general
        </a>
      </div>
    </section>

    <!-- WOLVERINE -->
    <section class="hub-card highlight">
      <h2>
        <span class="icon">★</span>
        Wolverine Airsoft Systems
      </h2>

      <p class="card-text">
        Sistemas HPA premium, configuraciones avanzadas y builds optimizadas.
      </p>

      <div class="hub-actions single">
        <a href="/wolverine/" class="btn-main">
          Ver sistemas Wolverine
        </a>
      </div>
    </section>

    <!-- GRID -->
    <section class="hub-grid">

      <a href="/comprar/" class="mini-card">
        <h3>Comprar</h3>
        <span>Catálogo online</span>
      </a>

      <a href="/eventos/" class="mini-card">
        <h3>Eventos</h3>
        <span>Competiciones</span>
      </a>

      <a href="/ir-a-jugar/" class="mini-card">
        <h3>Ir a jugar</h3>
        <span>Campos recomendados</span>
      </a>

      <a href="/novedades/" class="mini-card">
        <h3>Novedades</h3>
        <span>Últimos lanzamientos</span>
      </a>

      <a href="/saber/" class="mini-card">
        <h3>Saber</h3>
        <span>Blog y FAQs</span>
      </a>

    </section>

  </section>

</MainLayout>

<style>
.hub {
  max-width: 1100px;
  margin: 0 auto;
  padding: 40px 20px 60px;
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.hub-card {
  padding: 24px;
  border-radius: 18px;
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.05);
  transition: transform 0.25s ease, border-color 0.25s ease;
}

.hub-card:hover {
  transform: translateY(-6px);
  border-color: #ff3b2f;
}

.primary {
  border: 1px solid #ff3b2f;
}

.highlight {
  background: linear-gradient(135deg, #111827, #161e30);
  border: 1px solid rgba(255,59,47,0.5);
}

.icon {
  margin-right: 8px;
  opacity: 0.85;
}

.address {
  font-size: 0.85rem;
  opacity: 0.75;
  margin-bottom: 10px;
}

.hub-actions {
  margin-top: 16px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.hub-actions.single {
  margin-top: 6px;
}

.btn-main {
  background: #ff3b2f;
  padding: 11px 20px;
  border-radius: 12px;
  color: #fff;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-main:hover {
  transform: translateY(-2px);
}

.btn-secondary {
  border: 1px solid #ff3b2f;
  padding: 11px 20px;
  border-radius: 12px;
  color: #ff3b2f;
  font-weight: 600;
  text-decoration: none;
}

.hub-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 16px;
}

.mini-card {
  padding: 20px;
  border-radius: 16px;
  background: #111827;
  border: 1px solid rgba(255,255,255,0.05);
  text-decoration: none;
  color: white;
  transition: all 0.25s ease;
}

.mini-card:hover {
  transform: translateY(-4px);
  border-color: rgba(255,59,47,0.5);
}

.card-text {
  margin-bottom: 18px;
  opacity: 0.85;
}
</style>
