---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";
---

<MainLayout title="Airsoft Nation | Centro táctico especializado">

  <Hero />

  <section class="hub">

    <!-- TIENDA FÍSICA -->
    <div class="hub-card primary">
      <h2>Tienda Física · Celrà</h2>
      <p>Asesoramiento técnico, comunidad activa y atención especializada.</p>
      <div class="hub-actions">
        <a href="/contacto/" class="btn-main">Cómo llegar</a>
        <a href="/contacto-form/" class="btn-secondary">Contactar</a>
      </div>
    </div>

    <!-- HPA -->
    <div class="hub-card hpa">
      <h2>Centro Técnico HPA</h2>
      <p>Instalación y optimización de sistemas <strong>Wolverine Airsoft</strong>.</p>
      <div class="hub-actions">
        <a href="/hpa/" class="btn-main">Servicio HPA</a>
        <a href="/taller/" class="btn-secondary">Taller general</a>
      </div>
    </div>

    <!-- NOVEDAD WOLVERINE -->
    <div class="hub-card highlight">
      <h2>Novedad Wolverine</h2>
      <p>Configuraciones avanzadas y builds premium disponibles.</p>
      <a href="/comprar/" class="btn-main">Ver novedades</a>
    </div>

    <!-- ONLINE GRID -->
    <div class="hub-grid">
      <a href="/comprar/" class="mini-card">
        <h3>Comprar</h3>
        <span>Catálogo online</span>
      </a>
      <a href="/eventos/" class="mini-card">
        <h3>Eventos</h3>
        <span>Competiciones</span>
      </a>
      <a href="/ir-a-jugar/" class="mini-card">
        <h3>Ir a jugar</h3>
        <span>Campos recomendados</span>
      </a>
      <a href="/novedades/" class="mini-card">
        <h3>Novedades</h3>
        <span>Últimos lanzamientos</span>
      </a>
    </div>

  </section>

</MainLayout>

<style>
.hub {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.hub-card {
  padding: 20px;
  border-radius: 14px;
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.05);
}

.primary {
  border: 1px solid #E02B20;
}

.hpa {
  border: 1px solid rgba(224,43,32,0.35);
}

.highlight {
  background: linear-gradient(90deg, #111827, #1a1f2e);
  border: 1px solid rgba(224,43,32,0.4);
}

.hub-actions {
  margin-top: 12px;
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.btn-main {
  background: #E02B20;
  padding: 8px 16px;
  border-radius: 8px;
  color: #fff;
  text-decoration: none;
  font-weight: 600;
}

.btn-secondary {
  border: 1px solid #E02B20;
  padding: 8px 16px;
  border-radius: 8px;
  color: #E02B20;
  text-decoration: none;
  font-weight: 600;
}

.hub-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 12px;
}

.mini-card {
  padding: 16px;
  border-radius: 12px;
  background: #111827;
  border: 1px solid rgba(255,255,255,0.05);
  text-decoration: none;
  color: white;
}
</style>
