---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";

const routes = [
  { 
    name: "Visítanos en tienda",
    href: "/contacto/",
    icon: "store",
    type: "primary"
  },
  { 
    name: "Especialistas HPA",
    href: "/hpa/",
    icon: "bolt",
    type: "primary"
  },
  { 
    name: "Servicio técnico",
    href: "/taller/",
    icon: "tools",
    type: "primary"
  },
  { 
    name: "Comprar",
    href: "/comprar/",
    type: "secondary"
  },
  { 
    name: "Ir a jugar",
    href: "/ir-a-jugar/",
    type: "secondary"
  },
  { 
    name: "Eventos",
    href: "/eventos/",
    type: "secondary"
  },
  { 
    name: "Novedades",
    href: "/novedades/",
    type: "secondary"
  },
  { 
    name: "Contacto",
    href: "/contacto-form/",
    icon: "mail",
    type: "secondary"
  }
];
---

<MainLayout title="Airsoft Nation | Centro táctico especializado">

  <Hero />

  <section class="hpa-intro">
    <p>
      Centre technique spécialisé en systèmes HPA 
      <strong>Wolverine Airsoft</strong> pour joueurs exigeants.
    </p>
  </section>

  <div id="fr-cta" class="fr-cta" style="display:none;">
    Support, livraison et service HPA pour joueurs français 🇫🇷
  </div>

  <section class="linktree">
    {routes.map((route, i) => (
      <a
        href={route.href}
        class={`link-card ${route.type === "primary" ? "primary-link" : "secondary-link"}`}
        style={`animation-delay:${i * 0.08}s`}
      >

        {route.icon === "store" && (
          <svg class="link-icon" viewBox="0 0 24 24">
            <path d="M3 9l1-4h16l1 4v11a1 1 0 0 1-1 1h-4v-6H8v6H4a1 1 0 0 1-1-1V9z"/>
          </svg>
        )}

        {route.icon === "mail" && (
          <svg class="link-icon" viewBox="0 0 24 24">
            <path d="M2 4h20v16H2zM2 6l10 7L22 6"/>
          </svg>
        )}

        {route.icon === "tools" && (
          <svg class="link-icon" viewBox="0 0 24 24">
            <path d="M22 19l-6.3-6.3a5 5 0 0 0-6.4-6.4l3 3-2 2-3-3a5 5 0 0 0 6.4 6.4L19 22z"/>
          </svg>
        )}

        {route.icon === "bolt" && (
          <svg class="link-icon" viewBox="0 0 24 24">
            <path d="M13 2L3 14h7l-1 8 10-12h-7z"/>
          </svg>
        )}

        {route.name}
      </a>
    ))}
  </section>

</MainLayout>

<style>
.hpa-intro {
  text-align: center;
  padding: 12px 20px;
  font-size: 0.9rem;
  opacity: 0.85;
}

.fr-cta {
  text-align: center;
  background: linear-gradient(90deg, #002395, #ed2939);
  padding: 12px;
  font-weight: 600;
  margin: 15px;
  border-radius: 8px;
}

.linktree {
  padding: 16px;
  display: grid;
  gap: 12px;
}

.link-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 16px;
  border-radius: 14px;
  text-decoration: none;
  color: white;
  font-family: var(--font-title);
  font-weight: 500;
  text-align: center;
  border: 1px solid rgba(255,255,255,0.05);
  animation: fadeUp 0.5s ease forwards;
  opacity: 0;
  transition: all 0.25s ease;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.primary-link {
  background: linear-gradient(90deg, #0f172a, #111827);
  border: 1px solid rgba(0,180,255,0.3);
}

.secondary-link {
  background: #0f172a;
  opacity: 0.9;
}

.primary-link:hover {
  box-shadow: 0 0 22px rgba(0,180,255,0.35);
}

.link-card:hover {
  transform: translateY(-3px);
  border-color: var(--primary);
}

.link-card:active {
  transform: scale(0.98);
}

.link-icon {
  width: 18px;
  height: 18px;
  fill: var(--primary);
  opacity: 0.9;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
  if (document.documentElement.dataset.lang === "fr") {
    document.getElementById("fr-cta").style.display = "block";
  }
});
</script>
<script>
let scrollTracked = false;

window.addEventListener("scroll", () => {
  if (!scrollTracked && window.scrollY > 300) {
    scrollTracked = true;
    if (typeof gtag === "function") {
      gtag("event", "scroll_300");
    }
  }
});
</script>
