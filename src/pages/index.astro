---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";
---

<MainLayout title="Airsoft Nation | Centro táctico especializado">

  <Hero />

  <section class="hub">

    <!-- BLOQUE TIENDA FÍSICA -->
    <div class="hub-card primary">
      <h2>Visítanos en tienda</h2>
      <p>
        Celrà (Girona). Atención especializada, asesoramiento técnico y
        comunidad activa.
      </p>

      <div class="hub-actions">
        <a href="/contacto/" class="btn-main">Cómo llegar</a>
        <a href="/contacto-form/" class="btn-secondary">Contactar</a>
      </div>
    </div>

    <!-- BLOQUE HPA -->
    <div class="hub-card hpa">
      <h2>Centro Técnico HPA</h2>
      <p>
        Especialistas en instalación y optimización de sistemas
        <strong>Wolverine Airsoft</strong>.
      </p>

      <div class="hub-actions">
        <a href="/hpa/" class="btn-main">Servicio técnico HPA</a>
        <a href="/taller/" class="btn-secondary">Taller general</a>
      </div>
    </div>

    <!-- BLOQUE ONLINE -->
    <div class="hub-grid">

      <a href="/comprar/" class="mini-card">
        <h3>Comprar</h3>
        <span>Catálogo y novedades</span>
      </a>

      <a href="/eventos/" class="mini-card">
        <h3>Eventos</h3>
        <span>Competiciones y partidas</span>
      </a>

      <a href="/ir-a-jugar/" class="mini-card">
        <h3>Ir a jugar</h3>
        <span>Campos recomendados</span>
      </a>

      <a href="/novedades/" class="mini-card">
        <h3>Novedades</h3>
        <span>Últimos lanzamientos</span>
      </a>

    </div>

  </section>

</MainLayout>

<style>
.hub {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* CARDS PRINCIPALES */
.hub-card {
  padding: 24px;
  border-radius: 16px;
  background: linear-gradient(
    180deg,
    rgba(15,23,42,0.95),
    rgba(10,15,30,0.95)
  );
  border: 1px solid rgba(255,255,255,0.05);
  transition: 0.25s ease;
}

.hub-card h2 {
  margin-bottom: 8px;
}

.hub-card p {
  opacity: 0.85;
  margin-bottom: 18px;
}

/* BLOQUE TIENDA DESTACADO */
.primary {
  border: 1px solid #E02B20;
  box-shadow: 0 0 20px rgba(224,43,32,0.15);
}

/* BLOQUE HPA */
.hpa {
  border: 1px solid rgba(224,43,32,0.35);
}

/* BOTONES */
.hub-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.btn-main {
  padding: 10px 18px;
  background: #E02B20;
  color: #fff;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
  font-family: 'Oswald', sans-serif;
}

.btn-main:hover {
  opacity: 0.9;
}

.btn-secondary {
  padding: 10px 18px;
  border: 1px solid #E02B20;
  color: #E02B20;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
  font-family: 'Oswald', sans-serif;
}

/* GRID SECUNDARIO */
.hub-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 14px;
}

.mini-card {
  padding: 18px;
  border-radius: 12px;
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.05);
  text-decoration: none;
  color: white;
  transition: 0.25s ease;
}

.mini-card:hover {
  border-color: #E02B20;
  transform: translateY(-2px);
}

.mini-card h3 {
  margin-bottom: 6px;
  font-size: 1rem;
}

.mini-card span {
  font-size: 0.8rem;
  opacity: 0.7;
}
</style>
