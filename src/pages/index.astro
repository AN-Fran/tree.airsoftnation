---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import CTASection from "../components/CTASection.astro";

const features = [
  {
    title: "Comunidad",
    text: "Únete a jugadores apasionados y vive el airsoft como debe ser."
  },
  {
    title: "Eventos",
    text: "Organizamos partidas, milsim y experiencias tácticas únicas."
  },
  {
    title: "Formación",
    text: "Aprende técnica, mantenimiento y estrategia."
  }
];
---

<MainLayout
  title="Airsoft Nation | Comunidad de Airsoft"
  description="Eventos, juego, formación y tienda especializada en airsoft."
>

  <Hero 
    title="Más que Airsoft"
    subtitle="Juego, comunidad y formación en un mismo lugar."
    primaryText="Ver próximos eventos"
    primaryHref="/eventos/"
  />

  <FeatureGrid items={features} />

  <CTASection
    title="¿Preparado para jugar?"
    text="Descubre nuestros próximos eventos y vive la experiencia."
    buttonText="Ir a eventos"
    buttonHref="/eventos/"
  />

</MainLayout>
