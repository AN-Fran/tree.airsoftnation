---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";

const routes = [
  { 
    name: "Visítanos en tienda",
    href: "/contacto/",
    icon: "store"
  },
  { 
    name: "Contacto",
    href: "/contacto-form/",
    icon: "mail"
  },
  { 
    name: "Servicio técnico",
    href: "/taller/",
    icon: "tools"
  },
  { name: "Saber", href: "/saber/" },
  { name: "Ir a jugar", href: "/ir-a-jugar/" },
  { name: "Eventos", href: "/eventos/" },
  { name: "Novedades", href: "/novedades/" },
  { name: "Comprar", href: "/comprar/" }
];
---

<MainLayout title="Airsoft Nation | Comunidad táctica">

  <Hero />

  <section class="linktree">
    {routes.map((route, i) => (
      <a
        href={route.href}
        class={`link-card ${i < 3 ? "primary-link" : ""}`}
        style={`animation-delay:${i * 0.08}s`}
      >

        {/* Iconos */}
        {route.icon === "store" && (
          <svg class="link-icon" viewBox="0 0 24 24">
            <path d="M3 9l1-4h16l1 4v11a1 1 0 0 1-1 1h-4v-6H8v6H4a1 1 0 0 1-1-1V9z"/>
          </svg>
        )}

        {route.icon === "mail" && (
          <svg class="link-icon" viewBox="0 0 24 24">
            <path d="M2 4h20v16H2zM2 6l10 7L22 6"/>
          </svg>
        )}

        {route.icon === "tools" && (
          <svg class="link-icon" viewBox="0 0 24 24">
            <path d="M22 19l-6.3-6.3a5 5 0 0 0-6.4-6.4l3 3-2 2-3-3a5 5 0 0 0 6.4 6.4L19 22z"/>
          </svg>
        )}

        {route.name}
      </a>
    ))}
  </section>

</MainLayout>

<style>
.linktree {
  padding: 24px;
  display: grid;
  gap: 16px;
}

.link-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 18px;
  border-radius: 14px;
  background: #111827;
  text-decoration: none;
  color: white;
  font-family: var(--font-title);
  font-weight: 500;
  text-align: center;
  border: 1px solid rgba(255,255,255,0.05);
  animation: fadeUp 0.5s ease forwards;
  opacity: 0;
  transition: all 0.25s ease;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.primary-link {
  background: linear-gradient(90deg, #0f172a, #111827);
  border: 1px solid rgba(0,180,255,0.3);
}

.primary-link:hover {
  box-shadow: 0 0 22px rgba(0,180,255,0.35);
}

.link-card:hover {
  transform: translateY(-3px);
  border-color: var(--primary);
}

.link-card:active {
  transform: scale(0.98);
}

.link-icon {
  width: 18px;
  height: 18px;
  fill: var(--primary);
  opacity: 0.9;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
