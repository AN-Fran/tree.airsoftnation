---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";

const routes = [
  { name: "Saber", href: "/saber/" },
  { name: "Ir a jugar", href: "/ir-a-jugar/" },
  { name: "Eventos", href: "/eventos/" },
  { name: "Taller", href: "/taller/" },
  { name: "Novedades", href: "/novedades/" },
  { name: "Comprar", href: "/comprar/" }
];
---

<MainLayout title="Airsoft Nation | Comunidad táctica">

  <Hero />

  <section class="linktree">
    {routes.map((route, i) => (
      <a
        href={route.href}
        class="link-card"
        style={`animation-delay:${i * 0.1}s`}
      >
        {route.name}
      </a>
    ))}
  </section>

</MainLayout>

<style>
.linktree {
  padding: 20px;
  display: grid;
  gap: 16px;
}

.link-card {
  display: block;
  padding: 18px;
  border-radius: 14px;
  background: #111827;
  text-decoration: none;
  color: white;
  font-weight: 500;
  text-align: center;
  border: 1px solid rgba(255,255,255,0.05);
  animation: fadeUp 0.5s ease forwards;
  opacity: 0;
  transition: transform 0.2s ease, border 0.2s ease;
}

.link-card:hover {
  transform: translateY(-3px);
  border-color: #00b894;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
<a 
  href="https://maps.app.goo.gl/vLG19SnL58wq81L27" 
  target="_blank"
  rel="noopener"
  class="link-button location-button"
>
  <span class="icon">📍</span>
  Tienda Física
</a>

