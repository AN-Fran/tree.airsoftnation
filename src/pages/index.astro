---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";
---

<MainLayout title="Airsoft Nation | Centro táctico especializado">

  <Hero />

  <section class="hub">

    <!-- TIENDA FÍSICA -->
    <div class="hub-card primary">
      <h2>🏬 Tienda Física · Celrà</h2>
      <p class="address">
        C. Just Puig, local 14 · 17460 Celrà (Girona)
      </p>
      <p>
        Asesoramiento técnico especializado, comunidad activa y atención profesional.
      </p>

      <div class="hub-actions">
        <a href="https://maps.app.goo.gl/qZ9mKjF6iWpGxFBG7"
           target="_blank"
           class="btn-main">
          Cómo llegar
        </a>

        <a href="/contacto-form/" class="btn-secondary">
          Contactar
        </a>
      </div>
    </div>

    <!-- CENTRO TÉCNICO HPA -->
    <div class="hub-card hpa">
      <h2>🔧 Centro Técnico HPA</h2>
      <p>
        Instalación, configuración y optimización avanzada de sistemas HPA.
      </p>

      <div class="hub-actions">
        <a href="/hpa/" class="btn-main">
          Servicio HPA
        </a>

        <a href="/taller/" class="btn-secondary">
          Taller general
        </a>
      </div>
    </div>

    <!-- WOLVERINE -->
    <div class="hub-card highlight">
      <h2>⭐ Wolverine Airsoft Systems</h2>
      <p>
        Sistemas HPA premium, configuraciones avanzadas y builds optimizadas para máximo rendimiento.
      </p>

      <a href="/wolverine/" class="btn-main">
        Ver sistemas Wolverine
      </a>
    </div>

    <!-- GRID ONLINE -->
    <div class="hub-grid">

      <a href="/comprar/" class="mini-card">
        <h3>Comprar</h3>
        <span>Catálogo online</span>
      </a>

      <a href="/eventos/" class="mini-card">
        <h3>Eventos</h3>
        <span>Competiciones</span>
      </a>

      <a href="/ir-a-jugar/" class="mini-card">
        <h3>Ir a jugar</h3>
        <span>Campos recomendados</span>
      </a>

      <a href="/novedades/" class="mini-card">
        <h3>Novedades</h3>
        <span>Últimos lanzamientos</span>
      </a>

      <a href="/saber/" class="mini-card">
        <h3>Saber</h3>
        <span>Blog y FAQs</span>
      </a>

    </div>

  </section>

</MainLayout>

<style>
.hub {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

/* CARDS PRINCIPALES */
.hub-card {
  padding: 22px;
  border-radius: 16px;
  background: #0f172a;
  border: 1px solid rgba(255,255,255,0.05);
  transition: all 0.25s ease;
}

.hub-card:hover {
  transform: translateY(-4px);
  border-color: #E02B20;
}

/* TIENDA DESTACADA */
.primary {
  border: 1px solid #E02B20;
}

/* HPA */
.hpa {
  border: 1px solid rgba(224,43,32,0.35);
}

/* WOLVERINE */
.highlight {
  background: linear-gradient(135deg, #111827, #151c2d);
  border: 1px solid rgba(224,43,32,0.4);
}

.address {
  font-size: 0.85rem;
  opacity: 0.75;
  margin-bottom: 8px;
}

/* BOTONES */
.hub-actions {
  margin-top: 14px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.btn-main {
  background: #E02B20;
  padding: 10px 18px;
  border-radius: 10px;
  color: #fff;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.25s ease;
}

.btn-main:hover {
  transform: translateY(-2px);
  background: #ff3b2f;
}

.btn-secondary {
  border: 1px solid #E02B20;
  padding: 10px 18px;
  border-radius: 10px;
  color: #E02B20;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.25s ease;
}

.btn-secondary:hover {
  background: rgba(224,43,32,0.08);
}

/* GRID SECUNDARIO */
.hub-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 14px;
}

.mini-card {
  padding: 18px;
  border-radius: 14px;
  background: #111827;
  border: 1px solid rgba(255,255,255,0.05);
  text-decoration: none;
  color: white;
  transition: all 0.25s ease;
}

.mini-card:hover {
  transform: translateY(-3px);
  border-color: rgba(224,43,32,0.5);
}

.mini-card h3 {
  margin-bottom: 4px;
  font-size: 1rem;
}

.mini-card span {
  font-size: 0.85rem;
  opacity: 0.7;
}
</style>

