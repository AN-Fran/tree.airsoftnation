---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";

const storeLinks = [
  {
    name: "Kits de iniciación",
    desc: "Empieza con una base equilibrada y fiable.",
    href: "https://airsoftnation.store/shop/category/kits-iniciacion-airsoft",
    icon: "bag"
  },
  {
    name: "Bases para upgrade",
    desc: "Plataformas sólidas para evolucionar.",
    href: "https://airsoftnation.store/shop/category/bases-upgrade",
    icon: "layers"
  },
  {
    name: "Mejorar precisión",
    desc: "Gana consistencia y alcance real.",
    href: "https://airsoftnation.store/shop/category/mejorar-precision",
    icon: "target"
  },
  {
    name: "Mejorar respuesta",
    desc: "Disparo más rápido y reactivo.",
    href: "https://airsoftnation.store/shop/category/mejorar-respuesta",
    icon: "bolt"
  }
];
---

<MainLayout title="Tienda | Airsoft Nation">

  <Hero />

  <section class="linktree">

    <div class="section-title">
      Por dónde comenzar
    </div>

    {storeLinks.map((item, i) => (
      <a
        href={item.href}
        target="_blank"
        rel="noopener noreferrer"
        class="link-card"
        style={`animation-delay:${i * 0.1}s`}
      >
        <div class="card-icon">
          {item.icon === "bag" && (
            <svg viewBox="0 0 24 24">
              <path d="M6 7V6a6 6 0 0112 0v1h2v13H4V7h2zm2 0h8V6a4 4 0 00-8 0v1z"/>
            </svg>
          )}
          {item.icon === "layers" && (
            <svg viewBox="0 0 24 24">
              <path d="M12 2l10 6-10 6L2 8l10-6zm0 10l10 6-10 6-10-6 10-6z"/>
            </svg>
          )}
          {item.icon === "target" && (
            <svg viewBox="0 0 24 24">
              <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 4a6 6 0 110 12 6 6 0 010-12zm0 4a2 2 0 100 4 2 2 0 000-4z"/>
            </svg>
          )}
          {item.icon === "bolt" && (
            <svg viewBox="0 0 24 24">
              <path d="M13 2L3 14h7v8l10-12h-7z"/>
            </svg>
          )}
        </div>

        <div class="card-text">
          <span class="card-title">{item.name}</span>
          <span class="card-desc">{item.desc}</span>
        </div>
      </a>
    ))}

    <div class="conversion-cta">
      ¿No sabes qué elegir?
      <a 
        href="https://wa.me/34614212918"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-button"
      >
        Hablar con asesor
      </a>
    </div>

  </section>

</MainLayout>

<style>
.linktree {
  padding: 20px;
  display: grid;
  gap: 16px;
}

/* Título sección */
.section-title {
  text-align: center;
  font-family: var(--font-title);
  letter-spacing: 2px;
  font-size: 0.8rem;
  opacity: 0.6;
  margin-bottom: 10px;
}

/* Tarjetas */
.link-card {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 18px;
  border-radius: 16px;
  background: #111827;
  text-decoration: none;
  color: white;
  border: 1px solid rgba(255,255,255,0.05);
  animation: fadeUp 0.5s ease forwards;
  opacity: 0;
  transition: transform 0.2s ease, border 0.2s ease, box-shadow 0.2s ease;
}

.link-card:hover {
  transform: translateY(-3px);
  border-color: #00b894;
  box-shadow: 0 0 25px rgba(0,184,148,0.25);
}

/* Icono */
.card-icon {
  width: 34px;
  height: 34px;
  flex-shrink: 0;
}

.card-icon svg {
  width: 100%;
  height: 100%;
  fill: white;
  opacity: 0.85;
}

/* Texto */
.card-text {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-family: var(--font-title);
  font-size: 1rem;
  letter-spacing: 0.5px;
}

.card-desc {
  font-family: var(--font-text);
  font-size: 0.75rem;
  opacity: 0.6;
}

/* Conversión */
.conversion-cta {
  margin-top: 30px;
  text-align: center;
  font-family: var(--font-text);
  font-size: 0.85rem;
  opacity: 0.7;
}

.cta-button {
  display: inline-block;
  margin-top: 10px;
  padding: 10px 18px;
  border-radius: 30px;
  background: linear-gradient(135deg, #00b894, #0984e3);
  color: white;
  text-decoration: none;
  font-family: var(--font-title);
  letter-spacing: 1px;
  font-size: 0.8rem;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.cta-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 25px rgba(0,184,148,0.4);
}

/* Animación */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
