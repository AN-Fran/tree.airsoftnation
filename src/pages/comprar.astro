---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";

const storeLinks = [
  {
    name: "Kits de iniciación",
    href: "https://airsoftnation.store/shop/category/kits-iniciacion-airsoft"
  },
  {
    name: "Bases para upgrade",
    href: "https://airsoftnation.store/shop/category/bases-upgrade"
  },
  {
    name: "Mejorar precisión",
    href: "https://airsoftnation.store/shop/category/mejorar-precision"
  },
  {
    name: "Mejorar respuesta",
    href: "https://airsoftnation.store/shop/category/mejorar-respuesta"
  }
];
---

<MainLayout title="Tienda | Airsoft Nation">

  <Hero />

  <section class="linktree">

    <div class="section-title">
      Por dónde comenzar
    </div>

    {storeLinks.map((item, i) => (
      <a
        href={item.href}
        target="_blank"
        rel="noopener"
        class="link-card"
        style={`animation-delay:${i * 0.1}s`}
      >
        {item.name}
      </a>
    ))}

  </section>

</MainLayout>

<style>
.section-title {
  font-family: var(--font-title);
  text-transform: uppercase;
  letter-spacing: 2px;
  font-size: 0.9rem;
  opacity: 0.7;
  margin-bottom: 16px;
  text-align: center;
}
</style>
