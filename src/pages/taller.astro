---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Servicio Técnico | Airsoft Nation">

<section class="contact-wrapper">

  <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" class="contact-logo" />

  <div class="brand-claim">
    ENCUENTRA TUS LÍMITES, CON CRITERIO.<br />
    DECISIONES QUE FUNCIONAN EN CAMPO.
  </div>

  <h1 class="form-title">SERVICIO TÉCNICO</h1>
  <p class="subtitle">
    Envíanos los datos de tu réplica y crearemos tu orden de trabajo.
  </p>

  <form method="POST" action="/api/ticket" class="form-grid">

    <input type="text" name="name" placeholder="Nombre y apellidos" required />
    <input type="email" name="email" placeholder="Email" required />
    <input type="tel" name="phone" placeholder="Teléfono" required />

    <select name="brand" required>
      <option value="">Marca de la réplica</option>
      <option>Tokyo Marui</option>
      <option>Specna Arms</option>
      <option>VFC</option>
      <option>G&G</option>
      <option>ICS</option>
      <option>LCT</option>
      <option>E&L</option>
      <option>Cyma</option>
      <option>Ares</option>
      <option>KWA</option>
      <option>WE</option>
      <option>Krytac</option>
      <option>Classic Army</option>
      <option>Umarex</option>
      <option>ASG</option>
      <option>Arcturus</option>
      <option>Double Eagle</option>
      <option>Jing Gong</option>
      <option>A&K</option>
      <option>Army Armament</option>
      <option>KWC</option>
      <option>Lancer Tactical</option>
      <option>Bo Manufactures</option>
      <option>Gate</option>
      <option>Saigo</option>
      <option>Secutor</option>
      <option>Evolution</option>
      <option>Otra</option>
    </select>

    <input type="text" name="model" placeholder="Modelo (ej: M4 / AR15)" />
    <input type="text" name="serialNumber" placeholder="Número de serie" />

    <textarea name="message" placeholder="Describe el problema o servicio que necesitas" required></textarea>

    <label class="privacy">
      <input type="checkbox" required />
      He leído y acepto la
      <a href="https://airsoftnation.eu/politica-de-privacidad/" target="_blank">
        política de privacidad
      </a>
    </label>

    <button type="submit" class="btn-submit">
      CREAR ORDEN DE SERVICIO
    </button>

  </form>

  <div class="powered">
    <img src="/Wolverine Airsoft Claws White.svg" alt="Wolverine Airsoft" />
    <span>HPA · CNC · PRECISIÓN · POWERED BY WOLVERINE AIRSOFT</span>
  </div>

</section>

<style>
.contact-wrapper {
  max-width: 480px;
  margin: 0 auto;
  padding: 50px 20px 180px;
  text-align: center;
}

/* LOGO */
.contact-logo {
  width: 220px;
  margin-bottom: 18px;
  filter: brightness(1.2);
}

/* CLAIM */
.brand-claim {
  font-size: 0.8rem;
  letter-spacing: 1px;
  opacity: 0.75;
  margin-bottom: 24px;
}

/* TITULOS */
.form-title {
  font-size: 1.7rem;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 0.9rem;
  margin-bottom: 30px;
  opacity: 0.8;
}

/* FORM */
.form-grid {
  display: grid;
  gap: 16px;
}

.form-grid input,
.form-grid select,
.form-grid textarea {
  padding: 14px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.06);
  background: #111827;
  color: white;
  font-size: 0.9rem;
}

.form-grid textarea {
  min-height: 110px;
  resize: none;
}

/* PRIVACY */
.privacy {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  opacity: 0.75;
  text-align: left;
}

.privacy input {
  margin: 0;
}

.privacy a {
  color: #00b894;
  text-decoration: none;
}

/* BUTTON */
.btn-submit {
  margin-top: 8px;
  padding: 16px;
  border-radius: 30px;
  border: none;
  background: linear-gradient(135deg, #00b894, #0984e3);
  color: white;
  font-weight: 600;
  letter-spacing: 1px;
  cursor: pointer;
}

/* POWERED */
.powered {
  margin-top: 32px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  opacity: 0.6;
}

.powered img {
  width: 130px;
  height: auto;
}

.powered span {
  font-size: 0.75rem;
  letter-spacing: 1px;
}

/* FOOTER */
.form-footer {
  margin-top: 18px;
  font-size: 0.7rem;
  opacity: 0.55;
  line-height: 1.4;
}
</style>

</MainLayout>
