---
import FormLayout from "../layouts/FormLayout.astro";
import Hero from "../components/hero.astro";
---

<FormLayout title="Servicio Técnico | Airsoft Nation">

  <Hero />

  <section class="contact-container">

    <h1 class="form-title">Servicio Técnico</h1>
    <p class="subtitle">
      Envíanos los datos de tu réplica y crearemos tu orden de trabajo.
    </p>

    <form id="ticket-form" class="form-grid">

      <!-- Honeypot anti-spam -->
      <input type="text" name="company" class="hidden-field" />

      <input type="text" name="name" placeholder="Nombre y apellidos" required />

      <input 
        type="tel" 
        name="phone" 
        placeholder="Teléfono (+34660000000)" 
        required 
      />

      <input type="email" name="email" placeholder="Email" required />

      <select name="brand" required>
        <option value="">Marca de la réplica</option>
        <option>Tokyo Marui</option>
        <option>Specna Arms</option>
        <option>VFC</option>
        <option>G&G</option>
        <option>ICS</option>
        <option>LCT</option>
        <option>E&L</option>
        <option>Cyma</option>
        <option>Ares</option>
        <option>KWA</option>
        <option>WE</option>
        <option>Krytac</option>
        <option>Classic Army</option>
        <option>Umarex</option>
        <option>ASG</option>
        <option>Arcturus</option>
        <option>Double Eagle</option>
        <option>Otra</option>
      </select>

      <input type="text" name="model" placeholder="Modelo (ej: M4 / AR15)" />
      <input type="text" name="serialNumber" placeholder="Número de serie" />

      <textarea
        name="message"
        placeholder="Describe el problema o servicio que necesitas"
        required
      ></textarea>

      <label class="privacy">
        <input type="checkbox" required />
        <span>
          He leído y acepto la
          <a href="https://airsoftnation.eu/politica-de-privacidad/" target="_blank">
            política de privacidad
          </a>
        </span>
      </label>

      <button type="submit" class="btn-submit">
        Crear orden de servicio
      </button>

      <p id="form-message" class="form-message"></p>

    </form>

  </section>

</FormLayout>

<style>
.contact-container {
  max-width: 520px;
  margin: 0 auto;
  padding: 2rem 1rem 3rem;
}

.form-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

input,
select,
textarea {
  width: 100%;
  padding: 0.75rem;
  border-radius: 6px;
  border: none;
  font-size: 0.95rem;
}

textarea {
  min-height: 120px;
  resize: vertical;
}

.privacy {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
}

.btn-submit {
  background: #ffffff;
  color: #000;
  padding: 0.8rem;
  border-radius: 6px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.2s ease;
}

.btn-submit:hover {
  opacity: 0.9;
}

.form-message {
  font-size: 0.9rem;
}

.form-message.success {
  color: #3ddc84;
}

.form-message.error {
  color: #ff6b6b;
}
</style>

<script is:inline>
  console.log("TALLER JS CARGADO");

  document.addEventListener("DOMContentLoaded", () => {

    const form = document.getElementById("ticket-form");
    const messageBox = document.getElementById("form-message");

    if (!form) {
      console.log("Formulario no encontrado");
      return;
    }

    const phoneRegex = /^\+\d{9,15}$/;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const button = form.querySelector("button");
      button.disabled = true;
      button.innerText = "Enviando...";

      messageBox.innerText = "";
      messageBox.classList.remove("success", "error");

      const data = new FormData(form);

      if (data.get("company")) {
        button.disabled = false;
        button.innerText = "Crear orden de servicio";
        return;
      }

      const phone = data.get("phone")?.toString().trim();

      if (!phoneRegex.test(phone)) {
        messageBox.innerText =
          "El teléfono debe estar en formato internacional. Ejemplo: +34660000000";
        messageBox.classList.add("error");

        button.disabled = false;
        button.innerText = "Crear orden de servicio";
        return;
      }

      const payload = {
        name: data.get("name")?.toString().trim(),
        email: data.get("email")?.toString().trim(),
        phone: phone,
        brand: data.get("brand")?.toString().trim(),
        model: data.get("model")?.toString().trim(),
        serialNumber: data.get("serialNumber")?.toString().trim(),
        message: data.get("message")?.toString().trim(),
      };

      try {
        const response = await fetch("/api/ticket", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          messageBox.innerText = "Orden creada correctamente.";
          messageBox.classList.add("success");
          form.reset();
        } else {
          messageBox.innerText = "Error enviando la orden.";
          messageBox.classList.add("error");
        }

      } catch {
        messageBox.innerText = "Error de conexión.";
        messageBox.classList.add("error");
      }

      button.disabled = false;
      button.innerText = "Crear orden de servicio";
    });

  });
</script>
