---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Servicio Técnico | Airsoft Nation">

  <section class="contact-wrapper">

    <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" class="contact-logo" />

    <div class="brand-claim">
      ENCUENTRA TUS LÍMITES, CON CRITERIO.<br />
      DECISIONES QUE FUNCIONAN EN CAMPO.
    </div>

    <h1 class="form-title">SERVICIO TÉCNICO</h1>

    <p class="subtitle">
      Envíanos los datos de tu réplica y crearemos tu orden de trabajo.
    </p>

    <form method="POST" action="/api/ticket" class="form-grid">

      <input type="text" name="name" placeholder="Nombre y apellidos" required />
      <input type="email" name="email" placeholder="Email" required />
      <input type="tel" name="phone" placeholder="Teléfono" required />

      <select name="brand" required>
        <option value="">Marca de la réplica</option>
        <option>Tokyo Marui</option>
        <option>Specna Arms</option>
        <option>VFC</option>
        <option>G&G</option>
        <option>ICS</option>
        <option>LCT</option>
        <option>E&L</option>
        <option>Cyma</option>
        <option>Ares</option>
        <option>KWA</option>
        <option>WE</option>
        <option>Krytac</option>
        <option>Classic Army</option>
        <option>Umarex</option>
        <option>ASG</option>
        <option>Arcturus</option>
        <option>Double Eagle</option>
        <option>Jing Gong</option>
        <option>A&K</option>
        <option>Army Armament</option>
        <option>KWC</option>
        <option>Lancer Tactical</option>
        <option>Bo Manufactures</option>
        <option>Gate</option>
        <option>Saigo</option>
        <option>Secutor</option>
        <option>Evolution</option>
        <option>Otra</option>
      </select>

      <input type="text" name="model" placeholder="Modelo (ej: M4 / AR15)" />
      <input type="text" name="serialNumber" placeholder="Número de serie" />

      <textarea
        name="message"
        placeholder="Describe el problema o servicio que necesitas"
        required
      ></textarea>

      <label class="privacy">
        <input type="checkbox" required />
        He leído y acepto la
        <a href="https://airsoftnation.eu/politica-de-privacidad/" target="_blank">
          política de privacidad
        </a>
      </label>

      <button type="submit" class="btn-submit">
        CREAR ORDEN DE SERVICIO
      </button>

    </form>

    <footer class="form-footer">
      Registro de marca de la Unión Europea nº 19040186<br />
      © 2026 Airsoft Nation · Celrà (Girona)
    </footer>

  </section>

</MainLayout>

<style>
.contact-wrapper {
  max-width: 480px;
  margin: 0 auto;
  padding: 60px 20px 220px;
  text-align: center;
}

/* Logo equilibrado */
.contact-logo {
  width: 240px;
  margin-bottom: 25px;
  filter: brightness(1.35) drop-shadow(0 0 25px rgba(0,150,255,0.25));
}

/* Claim */
.brand-claim {
  font-size: 0.85rem;
  opacity: 0.7;
  margin-bottom: 30px;
  line-height: 1.4;
}

/* Título */
.form-title {
  font-family: var(--font-title);
  font-size: 1.8rem;
  letter-spacing: 1px;
  margin-bottom: 12px;
}

/* Subtítulo */
.subtitle {
  font-size: 0.95rem;
  opacity: 0.8;
  margin-bottom: 40px;
}

/* Form */
.form-grid {
  display: grid;
  gap: 16px;
  text-align: left;
}

.form-grid input,
.form-grid select,
.form-grid textarea {
  width: 100%;
  padding: 14px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.1);
  background: #111827;
  color: white;
  font-family: var(--font-text);
  font-size: 0.9rem;
}

.form-grid textarea {
  min-height: 120px;
  resize: vertical;
}

.form-grid input::placeholder,
.form-grid textarea::placeholder {
  color: rgba(255,255,255,0.5);
}

/* Checkbox */
.privacy {
  font-size: 0.75rem;
  opacity: 0.7;
  display: flex;
  gap: 8px;
  align-items: flex-start;
}

.privacy input {
  margin-top: 3px;
}

.privacy a {
  color: #00b894;
  text-decoration: none;
}

/* Botón */
.btn-submit {
  margin-top: 10px;
  padding: 16px;
  border-radius: 30px;
  border: none;
  background: linear-gradient(135deg, #00b894, #0096ff);
  color: white;
  font-family: var(--font-title);
  font-size: 0.9rem;
  letter-spacing: 1px;
  cursor: pointer;
  transition: transform 0.2s ease;
}

.btn-submit:active {
  transform: scale(0.97);
}

/* Footer visible */
.form-footer {
  margin-top: 60px;
  font-size: 0.65rem;
  opacity: 0.5;
  line-height: 1.4;
}
</style>
