---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Servicio Técnico | Airsoft Nation">

  <section class="contact-wrapper">

    <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" class="contact-logo" />

    <div class="brand-claim">
      ENCUENTRA TUS LÍMITES, CON CRITERIO.<br />
      DECISIONES QUE FUNCIONAN EN CAMPO.
    </div>

    <h1 class="form-title">SERVICIO TÉCNICO</h1>

    <p class="subtitle">
      Envíanos los datos de tu réplica y crearemos tu orden de trabajo.
    </p>

    <form method="POST" action="/api/ticket" class="form-grid">

      <input type="text" name="name" placeholder="Nombre y apellidos" required />
      <input type="email" name="email" placeholder="Email" required />
      <input type="tel" name="phone" placeholder="Teléfono" required />

      <select name="brand" required>
        <option value="">Marca de la réplica</option>
        <option>Tokyo Marui</option>
        <option>Specna Arms</option>
        <option>VFC</option>
        <option>G&G</option>
        <option>ICS</option>
        <option>LCT</option>
        <option>E&L</option>
        <option>Cyma</option>
        <option>Ares</option>
        <option>KWA</option>
        <option>WE</option>
        <option>Krytac</option>
        <option>Classic Army</option>
        <option>Umarex</option>
        <option>ASG</option>
        <option>Arcturus</option>
        <option>Double Eagle</option>
        <option>Jing Gong</option>
        <option>A&K</option>
        <option>Army Armament</option>
        <option>KWC</option>
        <option>Lancer Tactical</option>
        <option>Bo Manufactures</option>
        <option>Gate</option>
        <option>Saigo</option>
        <option>Secutor</option>
        <option>Evolution</option>
        <option>Otra</option>
      </select>

      <input type="text" name="model" placeholder="Modelo (ej: M4 / AR15)" />
      <input type="text" name="serialNumber" placeholder="Número de serie" />

      <textarea
        name="message"
        placeholder="Describe el problema o servicio que necesitas"
        required
      ></textarea>

      <label class="privacy">
        <input type="checkbox" required />
        <span>
          He leído y acepto la
          <a href="https://airsoftnation.eu/politica-de-privacidad/" target="_blank">
            política de privacidad
          </a>
        </span>
      </label>

      <button type="submit" class="btn-submit">
        CREAR ORDEN DE SERVICIO
      </button>

    </form>

    <div class="powered">
      <img src="/Wolverine Airsoft Claws White.svg" alt="Wolverine Airsoft" />
      <span>HPA · CNC · PRECISIÓN · POWERED BY WOLVERINE AIRSOFT</span>
    </div>

    <footer class="form-footer">
      Registro de marca de la Unión Europea nº 19040186<br />
      © 2026 Airsoft Nation · Celrà (Girona)
    </footer>

  </section>

</MainLayout>

<style>
.contact-wrapper {
  max-width: 480px;
  margin: 0 auto;
  padding: 40px 20px 200px;
  text-align: center;
}

.contact-logo {
  width: 220px;
  margin-bottom: 18px;
}

.brand-claim {
  font-size: 0.78rem;
  opacity: 0.75;
  letter-spacing: 1px;
  margin-bottom: 20px;
}

.form-title {
  font-size: 1.7rem;
  margin-bottom: 8px;
}

.subtitle {
  font-size: 0.9rem;
  opacity: 0.8;
  margin-bottom: 28px;
}

.form-grid {
  display: grid;
  gap: 14px;
}

.form-grid input,
.form-grid select,
.form-grid textarea {
  width: 100%;
  padding: 12px;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.1);
  background: #111827;
  color: white;
  font-size: 0.85rem;
  font-family: var(--font-text);
}

.form-grid textarea {
  min-height: 100px;
  resize: vertical;
}

.form-grid input:focus,
.form-grid select:focus,
.form-grid textarea:focus {
  outline: none;
  border-color: #00b894;
}

.privacy {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.72rem;
  opacity: 0.75;
  text-align: left;
}

.privacy input {
  margin: 0;
  flex-shrink: 0;
}

.privacy a {
  color: #00b894;
  text-decoration: none;
}

.btn-submit {
  margin-top: 4px;
  padding: 14px;
  border-radius: 30px;
  border: none;
  background: linear-gradient(135deg, #00b894, #0984e3);
  color: white;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.2s ease;
}

.btn-submit:active {
  transform: scale(0.96);
}

.powered {
  margin-top: 30px;
  opacity: 0.6;
  font-size: 0.7rem;
}

.powered img {
  width: 100px;
  margin-bottom: 6px;
}

.form-footer {
  margin-top: 24px;
  font-size: 0.65rem;
  opacity: 0.5;
  line-height: 1.4;
}
</style>
