---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Wolverine MTW MK18 2026 | Airsoft Nation">

<section class="wolverine-container">

  <!-- HERO PRODUCTO -->
  <div class="product-hero">
    <img
      src="/wolverine/01 - MTW-MK18-2026-Angled.webp"
      alt="Wolverine MTW MK18 2026 Daniel Defense Angled view"
      width="1200"
      height="800"
      loading="eager"
      class="hero-image"
    />
  </div>

  <!-- INFO PRINCIPAL -->
  <div class="product-info">

    <h1>Daniel Defense MK18 XB MTW 2026</h1>

    <p class="subtitle">
      Plataforma MTW licenciada Daniel Defense · Sistema Wolverine Airsoft
    </p>

    <p>
      Replica oficial MTW fabricada bajo licencia Daniel Defense.
      Diseñada para configuraciones HPA premium con arquitectura real AR-15,
      grabados CNC y construcción reforzada.
    </p>

    <div class="meta-box">
      <p><strong>SKU:</strong> MTW-DXBST-1000</p>
      <p><strong>Envío estimado:</strong> Abril 2026</p>
    </div>

    <div class="cta-row">
      <a href="/hpa/" class="btn-main">
        Solicitar configuración personalizada
      </a>

      <a href="/contacto-form/" class="btn-secondary">
        Consultar disponibilidad
      </a>
    </div>

  </div>

  <!-- GALERÍA -->
  <div class="gallery">

    <img src="/wolverine/02 - MTW-MK18-2026-Closeup-Lower.webp"
         alt="MTW MK18 2026 Closeup Lower Receiver"
         width="1200"
         height="800"
         loading="lazy" />

    <img src="/wolverine/03 - MTW-MK18-2026-Closeup-Upper.webp"
         alt="MTW MK18 2026 Closeup Upper Receiver"
         width="1200"
         height="800"
         loading="lazy" />

    <img src="/wolverine/04 - MTW-MK18-RIS-II-Closeup-Grip.webp"
         alt="MTW MK18 RIS II Grip Detail"
         width="1200"
         height="800"
         loading="lazy" />

    <img src="/wolverine/05 - MTW-MK18-RIS-II-Closeup-Stock.webp"
         alt="MTW MK18 RIS II Stock Detail"
         width="1200"
         height="800"
         loading="lazy" />

    <img src="/wolverine/06 - MTW-MK18-2026-Closeup-Rail.webp"
         alt="MTW MK18 2026 Rail Detail"
         width="1200"
         height="800"
         loading="lazy" />

    <img src="/wolverine/07 - MTW-MK18-2026-Right.webp"
         alt="MTW MK18 2026 Right View"
         width="1200"
         height="800"
         loading="lazy" />

    <img src="/wolverine/08 - MTW-MK18-2026-Left.webp"
         alt="MTW MK18 2026 Left View"
         width="1200"
         height="800"
         loading="lazy" />

  </div>

  <!-- BLOQUE PREORDER -->
  <div class="preorder-box">
    <h2>Calendario oficial</h2>

    <ul>
      <li><strong>Febero 2026:</strong>Preorder abierta</li>
      <li><strong>Abril/Mayo 2026:</strong> Envío inicial estimado</li>
    </ul>
  </div>

</section>

</MainLayout>

<style>
.wolverine-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 40px 20px 60px;
  display: flex;
  flex-direction: column;
  gap: 32px;
}

/* HERO */
.product-hero {
  border-radius: 16px;
  overflow: hidden;
  background: #0f172a;
}

.hero-image {
  width: 100%;
  height: auto;
  display: block;
}

/* INFO */
.product-info h1 {
  font-size: 2rem;
  margin-bottom: 6px;
}

.subtitle {
  opacity: 0.75;
  margin-bottom: 16px;
}

.meta-box {
  background: rgba(255,255,255,0.04);
  padding: 14px 16px;
  border-radius: 10px;
  margin: 16px 0;
}

.cta-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

/* BOTONES */
.btn-main {
  background: #E02B20;
  color: white;
  padding: 10px 18px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 600;
  transition: 0.2s ease;
}

.btn-main:hover {
  transform: translateY(-2px);
}

.btn-secondary {
  border: 1px solid #E02B20;
  color: #E02B20;
  padding: 10px 18px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 600;
}

/* GALERÍA */
.gallery {
  display: grid;
  gap: 18px;
}

.gallery img {
  width: 100%;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  border-radius: 14px;
  background: #0f172a;
  display: block;
}

/* PREORDER */
.preorder-box {
  background: #111827;
  border: 1px solid rgba(224,43,32,0.4);
  padding: 20px;
  border-radius: 12px;
}

/* DESKTOP OPTIMIZACIÓN */
@media (min-width: 900px) {

  .gallery {
    grid-template-columns: repeat(2, 1fr);
  }

}

</style>
