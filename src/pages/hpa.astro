---
import FormLayout from "../layouts/FormLayout.astro";
import Hero from "../components/hero.astro";
---

<FormLayout title="Especialistas HPA | Airsoft Nation">

<Hero />

<section class="contact-container">
  <div class="form-wrapper">

    <h1 class="form-title">Servicio Técnico HPA</h1>

    <p class="subtitle">
      Instalación y optimización de sistemas HPA Wolverine.
    </p>

    <form id="hpa-form" class="form-grid" method="POST" action="/api/hpa">

      <input type="text" name="company" class="honeypot" autocomplete="off" />

      <div class="form-row">
        <input type="text" name="name" placeholder="Nombre completo" required />
      </div>

      <div class="form-row">
        <input type="email" name="email" placeholder="Email" required />
      </div>

      <div class="form-row">
        <input type="tel" name="phone" placeholder="Teléfono" />
      </div>

      <div class="form-row">
        <textarea
          name="message"
          placeholder="Modelo de réplica, sistema HPA, uso (CQB/Speed), problema o mejora deseada"
          required
        ></textarea>
      </div>

      <label class="privacy">
        <input type="checkbox" name="consent" required />
        <span>
          He leído y acepto la
          <a
            href="https://airsoftnation.eu/politica-de-privacidad/"
            target="_blank"
            rel="noopener"
          >
            política de privacidad
          </a>
        </span>
      </label>

      <div id="form-message" class="form-message"></div>

      <button type="submit" class="btn-submit">
        Solicitar servicio técnico HPA
      </button>

    </form>

  </div>
</section>

</FormLayout>

<script>
document.getElementById("hpa-form")?.addEventListener("submit", async function(e) {
  e.preventDefault();
  const form = e.target;
  const formData = new FormData(form);

  const response = await fetch("/api/hpa", {
    method: "POST",
    body: formData
  });

  const messageBox = document.getElementById("form-message");

  if (response.ok) {
    messageBox.innerText = "Solicitud enviada correctamente.";
    form.reset();

    if (typeof gtag === "function") {
      gtag("event", "hpa_submit");
    }
  } else {
    messageBox.innerText = "Error al enviar. Inténtalo nuevamente.";
  }
});
</script>
