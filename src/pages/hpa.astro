---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/hero.astro";
---

<MainLayout title="Servicio Técnico HPA | Airsoft Nation">

<Hero />

<section class="hpa-hub">

  <div class="hpa-card">
    <h2>Servicio Técnico HPA</h2>
    <p>Optimización y configuración avanzada de sistemas Wolverine.</p>
  </div>

  <div class="hpa-card form-card">
    <form id="hpa-form" method="POST" action="/api/hpa">

      <input type="text" name="company" class="honeypot" />

      <input type="text" name="name" placeholder="Nombre completo" required />
      <input type="email" name="email" placeholder="Email" required />
      <input type="tel" name="phone" placeholder="Teléfono" />

      <textarea name="message"
        placeholder="Modelo de réplica, sistema HPA, uso y mejoras deseadas"
        required></textarea>

      <button type="submit" class="btn-main">
        Solicitar servicio técnico
      </button>

    </form>
  </div>

</section>

</MainLayout>

<style>
.hpa-hub {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.hpa-card {
  padding: 20px;
  border-radius: 14px;
  background: #0f172a;
  border: 1px solid rgba(224,43,32,0.35);
}

.form-card form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

input, textarea {
  padding: 10px;
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.2);
  background: #111827;
  color: white;
}

textarea {
  min-height: 100px;
}

.honeypot {
  display: none;
}
</style>
