---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Tienda Física | Airsoft Nation">

<section class="store-container">

  <!-- CABECERA -->
  <div class="store-header">
    <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" class="store-logo" />
    <h1>Visítanos en tienda</h1>
    <p class="store-subtitle">
      Airsoft Nation Store · Celrà (Girona)
    </p>
  </div>

  <!-- MAPA -->
  <div class="map-wrapper">
    <iframe
      src="https://www.google.com/maps?q=Airsoft+Nation+Store+Celrà&output=embed"
      loading="lazy"
      allowfullscreen
    ></iframe>
  </div>

  <!-- DIRECCIÓN -->
  <div class="store-section">
    <h2>Dirección</h2>
    <p>
      C. Just Puig, local 14<br/>
      17460 Celrà (Girona)<br/>
      Catalunya – Spain
    </p>

    <a
      href="https://www.google.com/maps/place/Airsoft+Nation+Store"
      target="_blank"
      class="btn-outline"
    >
      Abrir en Google Maps
    </a>
  </div>

  <!-- HORARIO -->
  <div class="store-section">
    <h2>Horario</h2>

    <div class="schedule">
      <strong>Lunes a jueves</strong>
      <span>11:00 – 14:00</span>
      <span>16:00 – 20:00</span>

      <strong>Viernes</strong>
      <span>11:00 – 14:00</span>
      <span>16:00 – 21:00</span>
    </div>
<p id="store-status" class="store-status"></p>



    <p class="schedule-note">
      Si necesitas venir fuera de horario, escríbenos mediante el formulario y buscamos una solución.
    </p>
  </div>

  <!-- BOTONES ESTRATÉGICOS -->
  <div class="store-actions">
    <a href="/contacto-form/" class="btn-primary">
      Contactar
    </a>

    <a href="/taller/" class="btn-secondary">
      Servicio Técnico
    </a>
  </div>

</section>
<Fragment slot="scripts">
<script>
  const statusElement = document.getElementById("store-status");

  function checkStoreStatus() {
    const now = new Date();
    const day = now.getDay(); // 0=domingo
    const hour = now.getHours();
    const minutes = now.getMinutes();
    const currentTime = hour + minutes / 60;

    let isOpen = false;

    if (day >= 1 && day <= 4) { // L-J
      if ((currentTime >= 11 && currentTime < 14) ||
          (currentTime >= 16 && currentTime < 20)) {
        isOpen = true;
      }
    }

    if (day === 5) { // Viernes
      if ((currentTime >= 11 && currentTime < 14) ||
          (currentTime >= 16 && currentTime < 21)) {
        isOpen = true;
      }
    }

    statusElement.textContent = isOpen
      ? "Abierto ahora"
      : "Cerrado en este momento";

    statusElement.style.color = isOpen ? "#3ddc84" : "#ff6b6b";
  }

  checkStoreStatus();
</script>

  <script type="application/ld+json">
