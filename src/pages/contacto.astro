---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Tienda Física | Airsoft Nation">

<section class="store-container">

  <!-- CABECERA -->
  <div class="store-header">
    <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" class="store-logo" />
    <h1>Visítanos en tienda</h1>
    <p class="store-subtitle">
      Airsoft Nation Store · Celrà (Girona)
    </p>
  </div>

  <!-- MAPA -->
  <div class="map-wrapper">
    <iframe
      src="https://www.google.com/maps?q=Airsoft+Nation+Store+Celrà&output=embed"
      loading="lazy"
      allowfullscreen
    ></iframe>
  </div>

  <!-- DIRECCIÓN -->
  <div class="store-section">
    <h2>Dirección</h2>
    <p>
      C. Just Puig, local 14<br/>
      17460 Celrà (Girona)<br/>
      Catalunya – Spain
    </p>

    <a
      href="https://www.google.com/maps/place/Airsoft+Nation+Store"
      target="_blank"
      class="btn-outline"
    >
      Abrir en Google Maps
    </a>
  </div>

  <!-- HORARIO -->
  <div class="store-section">
    <h2>Horario</h2>

    <div class="schedule">
      <strong>Lunes a jueves</strong>
      <span>11:00 – 14:00</span>
      <span>16:00 – 20:00</span>

      <strong>Viernes</strong>
      <span>11:00 – 14:00</span>
      <span>16:00 – 21:00</span>
    </div>

    <p class="schedule-note">
      Si necesitas venir fuera de horario, escríbenos mediante el formulario y buscamos una solución.
    </p>
  </div>

  <!-- BOTONES ESTRATÉGICOS -->
  <div class="store-actions">
    <a href="/contacto-form/" class="btn-primary">
      Contactar
    </a>

    <a href="/taller/" class="btn-secondary">
      Servicio Técnico
    </a>
  </div>

</section>

</MainLayout>

<style>
.store-container {
  max-width: 640px;
  margin: 0 auto;
  padding: 2.5rem 1.2rem 4rem;
}

/* HEADER */
.store-header {
  text-align: center;
  margin-bottom: 2.5rem;
}

.store-logo {
  width: 210px;
  max-width: 75%;
  margin: 0 auto 1.5rem;
  display: block;
  filter: drop-shadow(0 10px 25px rgba(0, 180, 255, 0.25));
}

.store-header h1 {
  font-size: 2.2rem;
  margin-bottom: 0.5rem;
}

.store-subtitle {
  opacity: 0.7;
  letter-spacing: 1px;
  font-size: 1rem;
}

/* MAPA */
.map-wrapper {
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 2.5rem;
  filter: grayscale(100%) contrast(105%);
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
}

.map-wrapper iframe {
  width: 100%;
  height: 280px;
  border: none;
}

/* SECCIONES */
.store-section {
  margin-bottom: 2.5rem;
}

.store-section h2 {
  margin-bottom: 0.8rem;
  font-size: 1.3rem;
  letter-spacing: 1px;
}

.store-section p {
  line-height: 1.6;
  opacity: 0.9;
}

/* HORARIO */
.schedule {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-bottom: 1rem;
}

.schedule strong {
  margin-top: 0.8rem;
  font-weight: 600;
}

.schedule-note {
  font-size: 0.9rem;
  opacity: 0.65;
}

/* BOTONES */
.store-actions {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.btn-primary {
  background: #e10600;
  color: white;
  padding: 0.9rem;
  border-radius: 8px;
  text-align: center;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-primary:hover {
  background: #ff1f1a;
  transform: translateY(-2px);
}

.btn-secondary {
  background: #f1f1f1;
  color: #000;
  padding: 0.9rem;
  border-radius: 8px;
  text-align: center;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-secondary:hover {
  background: #ffffff;
  transform: translateY(-2px);
}

.btn-outline {
  display: inline-block;
  margin-top: 1rem;
  padding: 0.6rem 1rem;
  border: 1px solid rgba(255,255,255,0.4);
  border-radius: 6px;
  text-decoration: none;
  color: white;
  font-size: 0.9rem;
  transition: all 0.2s ease;
}

.btn-outline:hover {
  border-color: white;
}
</style>
