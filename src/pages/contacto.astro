---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Contacto | Airsoft Nation">

<div class="store-header">

  <img 
    src="/logo_airsoft_nation.svg" 
    alt="Airsoft Nation Store"
    class="store-logo"
  />

  <h1>Visítanos en tienda</h1>
  <p class="store-subtitle">
    Airsoft Nation Store · Celrà (Girona)
  </p>

</div>

<section class="contact-page">

  <h1>Visítanos en tienda</h1>
  <p class="subtitle">
    Airsoft Nation Store · Celrà (Girona)
  </p>

  <div class="map-container">
    <iframe
      src="https://www.google.com/maps?q=Airsoft+Nation+Store,+Celrà&output=embed"
      width="100%"
      height="300"
      style="border:0; filter: grayscale(100%) contrast(1.1);"
      allowfullscreen=""
      loading="lazy">
    </iframe>
  </div>

  <div class="info-block">
    <h2>Dirección</h2>
    <p>
      C. Just Puig, local 14<br/>
      17460 Celrà (Girona)<br/>
      Catalunya – Spain
    </p>

    <a 
      href="https://www.google.com/maps/place/Airsoft+Nation+Store/"
      target="_blank"
      class="btn-outline"
    >
      Abrir en Google Maps
    </a>
  </div>

  <div class="info-block">
    <h2>Horario</h2>

    <p>
      <strong>Lunes a jueves</strong><br/>
      11:00 – 14:00<br/>
      16:00 – 20:00
    </p>

    <p>
      <strong>Viernes</strong><br/>
      11:00 – 14:00<br/>
      16:00 – 21:00
    </p>

    <p class="note">
      Si necesitas venir fuera de horario, escríbenos mediante el formulario y buscamos una solución.
    </p>
  </div>

  <div class="cta-buttons">
    <a href="/contacto-form/" class="btn-primary">
      Contactar
    </a>

    <a href="/taller/" class="btn-secondary">
      Servicio Técnico
    </a>
  </div>

</section>

</MainLayout>

<style>
.contact-page {
  max-width: 600px;
  margin: 0 auto;
  padding: 2rem 1rem 3rem;
}

.subtitle {
  opacity: 0.8;
  margin-bottom: 1.5rem;
}

.map-container {
  margin-bottom: 2rem;
  border-radius: 12px;
  overflow: hidden;
}

.info-block {
  margin-bottom: 2rem;
}

.note {
  font-size: 0.9rem;
  opacity: 0.8;
  margin-top: 1rem;
}

.cta-buttons {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.btn-primary {
  background: #e10600;
  color: white;
  padding: 0.9rem;
  text-align: center;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
}

.btn-secondary {
  background: white;
  color: black;
  padding: 0.9rem;
  text-align: center;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
}

.btn-outline {
  display: inline-block;
  margin-top: 0.8rem;
  padding: 0.6rem 1rem;
  border: 1px solid white;
  border-radius: 6px;
  text-decoration: none;
}
</style>

<style>
.store-header {
  text-align: center;
  margin-bottom: 2rem;
}

.store-logo {
  width: 120px;
  margin: 0 auto 1rem;
  display: block;
  opacity: 0.95;
}

.store-subtitle {
  opacity: 0.8;
  margin-top: 0.5rem;
  font-size: 0.95rem;
  letter-spacing: 1px;
}
</style>
