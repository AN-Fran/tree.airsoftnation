        "addressLocality": "Celrà",
        "postalCode": "17460",
        "addressRegion": "Girona",
        "addressCountry": "ES"
      },
      "url": "https://airsoftnation.eu/contacto/",
      "telephone": "+34614212918",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday","Tuesday","Wednesday","Thursday"
          ],
          "opens": "11:00",
          "closes": "20:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Friday",
          "opens": "11:00",
          "closes": "21:00"
        }
      ],
      "priceRange": "€€"
    }
  </script>
</Fragment>

<a href="https://wa.me/34614212918"
   target="_blank"
   class="whatsapp-float"
   aria-label="WhatsApp">
  <svg viewBox="0 0 24 24">
    <path d="M12 2a10 10 0 0 0-8.5 15l-1 5 5-1A10 10 0 1 0 12 2z"/>
  </svg>
</a>


<style>
.store-status {
  margin-top: 1rem;
  font-weight: 600;
}


.whatsapp-float {
  position: fixed;
  bottom: 90px;
  right: 20px;
  width: 56px;
  height: 56px;
  background: #25D366;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 20px rgba(0,0,0,0.35);
  z-index: 1000;
}

.whatsapp-float svg {
  width: 26px;
  height: 26px;
  fill: white;
}
</style>

</MainLayout>

<style>
.store-container {
  max-width: 640px;
  margin: 0 auto;
  padding: 2.5rem 1.2rem 4rem;
}

/* HEADER */
.store-header {
  text-align: center;
  margin-bottom: 2.5rem;
}

.store-logo {
  width: 210px;
  max-width: 75%;
  margin: 0 auto 1.5rem;
  display: block;
  filter: drop-shadow(0 10px 25px rgba(0, 180, 255, 0.25));
}

.store-header h1 {
  font-size: 2.2rem;
  margin-bottom: 0.5rem;
}

.store-subtitle {
  opacity: 0.7;
  letter-spacing: 1px;
  font-size: 1rem;
}

/* MAPA */
.map-wrapper {
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 2.5rem;
  filter: grayscale(100%) contrast(105%);
  box-shadow: 0 10px 30px rgba(0,0,0,0.35);
}

.map-wrapper iframe {
  width: 100%;
  height: 280px;
  border: none;
}

/* SECCIONES */
.store-section {
  margin-bottom: 2.5rem;
}

.store-section h2 {
  margin-bottom: 0.8rem;
  font-size: 1.3rem;
  letter-spacing: 1px;
}

.store-section p {
  line-height: 1.6;
  opacity: 0.9;
}

/* HORARIO */
.schedule {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-bottom: 1rem;
}

.schedule strong {
  margin-top: 0.8rem;
  font-weight: 600;
}

.schedule-note {
  font-size: 0.9rem;
  opacity: 0.65;
}

/* BOTONES */
.store-actions {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.btn-primary {
  background: #e10600;
  color: white;
  padding: 0.9rem;
  border-radius: 8px;
  text-align: center;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-primary:hover {
  background: #ff1f1a;
  transform: translateY(-2px);
}

.btn-secondary {
  background: #f1f1f1;
  color: #000;
  padding: 0.9rem;
  border-radius: 8px;
  text-align: center;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.25s ease;
}

.btn-secondary:hover {
  background: #ffffff;
  transform: translateY(-2px);
}

.btn-outline {
  display: inline-block;
  margin-top: 1rem;
  padding: 0.6rem 1rem;
  border: 1px solid rgba(255,255,255,0.4);
  border-radius: 6px;
  text-decoration: none;
  color: white;
  font-size: 0.9rem;
  transition: all 0.2s ease;
}

.btn-outline:hover {
  border-color: white;
}
</style>
