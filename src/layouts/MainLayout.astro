---
import "../styles/global.css";
import Footer from "../components/footer.astro";

const {
  title = "Airsoft Nation",
  description = "Comunidad, eventos y juego de airsoft."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {Astro.head}

  <!-- Preload fuentes -->
  <link rel="preload" href="/fonts/oswald-600.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/open-sans-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" as="image" href="/logo_airsoft_nation.svg" type="image/svg+xml">
</head>

<body>

  <main class="content">
    <slot />
  </main>

  <Footer />

  <!-- WhatsApp flotante -->
  <a href="https://wa.me/34614212918"
     class="floating-wa"
     target="_blank"
     aria-label="WhatsApp">
     💬
  </a>

  <slot name="scripts" />

  <!-- Language detection -->
  <script>
    (function () {
      const lang = navigator.language || navigator.userLanguage;
      const html = document.documentElement;

      if (lang?.startsWith("fr")) html.dataset.lang = "fr";
      else if (lang?.startsWith("en")) html.dataset.lang = "en";
      else html.dataset.lang = "es";
    })();
  </script>

  <!-- Cookie + GA -->
  <div id="cookie-banner" class="cookie-banner">
    <p>Utilizamos cookies para analizar el tráfico y mejorar la experiencia.</p>
    <button id="accept-cookies">Aceptar</button>
    <button id="reject-cookies">Rechazar</button>
  </div>

  <script>
    (function(){

      function loadGA(){
        var script = document.createElement("script");
        script.async = true;
        script.src = "https://www.googletagmanager.com/gtag/js?id=G-55QHT62H0";
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;

        gtag('js', new Date());
        gtag('config', 'G-55QHT62H0');
      }

      var consent = localStorage.getItem("ga_consent");

      if (consent === "accepted") {
        loadGA();
        document.getElementById("cookie-banner").style.display = "none";
      }

      document.getElementById("accept-cookies").onclick = function(){
        localStorage.setItem("ga_consent", "accepted");
        loadGA();
        document.getElementById("cookie-banner").style.display = "none";
      };

      document.getElementById("reject-cookies").onclick = function(){
        localStorage.setItem("ga_consent", "rejected");
        document.getElementById("cookie-banner").style.display = "none";
      };

    })();
  </script>

  <!-- Event Tracking -->
  <script>
    document.addEventListener("click", function (e) {

      if (typeof window.gtag !== "function") return;

      const link = e.target.closest("a");
      if (!link) return;

      const href = link.href || "";

      if (href.includes("maps")) gtag("event", "click_maps");
      if (href.includes("wa.me")) gtag("event", "click_whatsapp");
      if (href.includes("/contacto-form/")) gtag("event", "click_contact_form");
      if (href.includes("/taller/")) gtag("event", "click_servicio_tecnico");
      if (href.includes("/wolverine/")) gtag("event", "click_wolverine");
      if (href.includes("/hpa/")) gtag("event", "click_hpa");

    });
  </script>

</body>
</html>

<style>
.content {
  padding-bottom: 40px;
}

/* WhatsApp flotante */
.floating-wa {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: #25D366;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: white;
  text-decoration: none;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
  z-index: 60;
}

/* Cookie banner */
.cookie-banner {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #111;
  padding: 15px;
  text-align: center;
  z-index: 9999;
  font-size: 14px;
}

.cookie-banner button {
  margin: 6px;
  padding: 8px 14px;
}
</style>
