---
import "../styles/global.css";

const {
  title = "Airsoft Nation",
  description = "Comunidad, eventos y juego de airsoft."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />

  {Astro.head}

  <!-- Preload fuentes -->
  <link rel="preload" href="/fonts/oswald-600.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/open-sans-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" as="image" href="/logo_airsoft_nation.svg" type="image/svg+xml">
</head>

<body>

  <div class="app">
    <div class="app-content">
      <slot />
    </div>

    <nav class="bottom-nav">
      <a href="/" aria-label="Home">
        <svg viewBox="0 0 24 24">
          <path d="M3 11l9-8 9 8v9a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/>
        </svg>
      </a>

      <a href="/saber/" aria-label="Saber">
        <svg viewBox="0 0 24 24">
          <path d="M4 6h16v12H4z"/>
        </svg>
      </a>

      <a href="/taller/" aria-label="Taller">
        <svg viewBox="0 0 24 24">
          <path d="M14.7 6.3l3 3-7.4 7.4-3-3z"/>
        </svg>
      </a>

      <a href="https://www.google.com/maps/place/Airsoft+Nation+Store"
         target="_blank"
         aria-label="Ubicación">
        <svg viewBox="0 0 24 24">
          <path d="M12 2C8.1 2 5 5.1 5 9c0 5.3 7 13 7 13s7-7.7 7-13c0-3.9-3.1-7-7-7zm0 9.5c-1.4 0-2.5-1.1-2.5-2.5S10.6 6.5 12 6.5s2.5 1.1 2.5 2.5S13.4 11.5 12 11.5z"/>
        </svg>
      </a>

      <a href="https://wa.me/34614212918"
         target="_blank"
         aria-label="WhatsApp">
        <svg viewBox="0 0 24 24">
          <path d="M12 2a10 10 0 0 0-8.5 15l-1 5 5-1A10 10 0 1 0 12 2z"/>
        </svg>
      </a>

      <a href="https://www.instagram.com/airsoftnation.eu/"
         target="_blank"
         aria-label="Instagram">
        <svg viewBox="0 0 24 24">
          <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5z"/>
        </svg>
      </a>
    </nav>

    <div class="legal-bar">
      Registro de marca de la Unión Europea nº 19040186<br />
      © 2026 Airsoft Nation · Celrà (Girona)
    </div>
  </div>

  <slot name="scripts" />

  <!-- Language detection -->
  <script>
    (function () {
      const lang = navigator.language || navigator.userLanguage;
      const html = document.documentElement;

      if (lang && lang.startsWith("fr")) {
        html.setAttribute("data-lang", "fr");
      } else if (lang && lang.startsWith("en")) {
        html.setAttribute("data-lang", "en");
      } else {
        html.setAttribute("data-lang", "es");
      }
    })();
  </script>

  <!-- Cookie Banner + GA4 -->
  <div id="cookie-banner" style="position:fixed;bottom:0;left:0;width:100%;background:#111;padding:15px;text-align:center;z-index:9999;">
    <p style="margin:0 0 10px;color:#fff;font-size:14px;">
      Utilizamos cookies para analizar el tráfico y mejorar la experiencia.
    </p>
    <button id="accept-cookies" style="margin-right:10px;padding:8px 14px;">Aceptar</button>
    <button id="reject-cookies" style="padding:8px 14px;">Rechazar</button>
  </div>

  <script>
    (function(){

      function loadGA(){
        var script = document.createElement("script");
        script.async = true;
        script.src = "https://www.googletagmanager.com/gtag/js?id=G-55QHT62H0";
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;

        gtag('js', new Date());
        gtag('config', 'G-55QHT62H0');
      }

      var consent = localStorage.getItem("ga_consent");

      if (consent === "accepted") {
        loadGA();
        document.getElementById("cookie-banner").style.display = "none";
      }

      document.getElementById("accept-cookies").onclick = function(){
        localStorage.setItem("ga_consent", "accepted");
        loadGA();
        document.getElementById("cookie-banner").style.display = "none";
      };

      document.getElementById("reject-cookies").onclick = function(){
        localStorage.setItem("ga_consent", "rejected");
        document.getElementById("cookie-banner").style.display = "none";
      };

    })();
  </script>

  <!-- Event Tracking -->
  <script>
    document.addEventListener("click", function (e) {

      if (typeof window.gtag !== "function") return;

      const link = e.target.closest("a");
      if (!link) return;

      const href = link.href || "";

      if (href.includes("google.com/maps")) {
        gtag("event", "click_maps");
      }

      if (href.includes("wa.me")) {
        gtag("event", "click_whatsapp");
      }

      if (href.includes("/contacto-form/")) {
        gtag("event", "click_contact_form");
      }

      if (href.includes("/taller/")) {
        gtag("event", "click_servicio_tecnico");
      }

    });
  </script>

</body>
</html>
