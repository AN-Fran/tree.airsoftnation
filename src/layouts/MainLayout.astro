---
import "../styles/global.css";
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";

const {
  title = "Airsoft Nation",
  description = "Comunidad, eventos y juego de airsoft.",
  image = "/logo_airsoft_nation.svg",
  noIndex = false,
  url = "https://tree.airsoftnation.eu"
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Airsoft Nation",
  url,
  logo: `${url}/logo_airsoft_nation.svg`,
  sameAs: [
    "https://www.instagram.com/airsoftnation.eu/"
  ]
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <!-- Preload logo -->
    <link rel="preload" href="/logo_airsoft_nation.svg" as="image" type="image/svg+xml" />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {JSON.stringify(jsonLd)}
    </script>
  </head>

  <body>

    <Header />

    <main class="page">
      <slot />
    </main>

    <Footer />

    <!-- Bottom Nav (Mobile App Style) -->
    <nav class="bottom-nav">
      <a href="/">
        <span>🏠</span>
        Home
      </a>

      <a href="/saber/">
        <span>📘</span>
        Saber
      </a>

      <a href="/taller/">
        <span>🛠</span>
        Taller
      </a>

      <a href="https://wa.me/34614212918" target="_blank" rel="noopener">
        <span>💬</span>
        WhatsApp
      </a>

      <a href="https://www.instagram.com/airsoftnation.eu/" target="_blank" rel="noopener">
        <span>📷</span>
        Instagram
      </a>
    </nav>

    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        background: #0b1220;
        color: white;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .page {
        padding-bottom: 90px; /* espacio bottom nav */
        animation: pageFade 0.4s ease forwards;
      }

      /* Transición suave de página */
      @keyframes pageFade {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      /* Bottom nav estilo app */
      .bottom-nav {
        position: fixed;
        bottom: 0;
        width: 100%;
        display: flex;
        justify-content: space-around;
        align-items: center;
        padding: 10px 0 12px;
        background: rgba(17, 24, 39, 0.96);
        backdrop-filter: blur(12px);
        border-top: 1px solid rgba(255,255,255,0.08);
        z-index: 1000;
      }

      .bottom-nav a {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        font-size: 0.7rem;
        text-decoration: none;
        color: white;
        opacity: 0.75;
        transition: opacity 0.2s ease, transform 0.2s ease;
      }

      .bottom-nav a span {
        font-size: 1.1rem;
      }

      .bottom-nav a:hover {
        opacity: 1;
        transform: translateY(-2px);
      }

      /* Desktop */
      @media (min-width: 768px) {
        .bottom-nav {
          display: none;
        }

        .page {
          padding-bottom: 0;
        }
      }
    </style>

  </body>
</html>
