---
import "../styles/global.css";
import Footer from "../components/footer.astro";

const {
  title = "Airsoft Nation",
  description = "Comunidad, eventos y juego de airsoft."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#061630" />
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

  <title>{title}</title>
  <meta name="description" content={description} />
  {Astro.head}

  <!-- PWA -->
  <link rel="manifest" href="/manifest.json" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />

  <!-- Fonts -->
  <link rel="preload" href="/fonts/oswald-600.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/open-sans-400.woff2" as="font" type="font/woff2" crossorigin>

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>

<body>

  <div class="app-wrapper">

    <main class="content page-transition">
      <slot />
    </main>

    <Footer />

  </div>

  <!-- Cookie banner -->
  <div id="cookie-banner" class="cookie-banner">
    <p>Utilizamos cookies para analizar el tráfico y mejorar la experiencia.</p>
    <div class="cookie-actions">
      <button id="accept-cookies" class="btn-primary">Aceptar</button>
      <button id="reject-cookies" class="btn-secondary">Rechazar</button>
    </div>
  </div>

  <!-- Service Worker -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => reg.update())
          .catch(err => console.log('SW error', err));
      });
    }
  </script>

  <!-- Cookie + GA -->
  <script>
    (function(){

      const banner = document.getElementById("cookie-banner");

      function adjustLayout() {
        document.body.classList.toggle("banner-visible", banner.style.display !== "none");
      }

      function loadGA(){
        var script = document.createElement("script");
        script.async = true;
        script.src = "https://www.googletagmanager.com/gtag/js?id=G-55QHT62H0";
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;

        gtag('js', new Date());
        gtag('config', 'G-55QHT62H0');
      }

      var consent = localStorage.getItem("ga_consent");

      if (consent === "accepted") {
        loadGA();
        banner.style.display = "none";
      }

      adjustLayout();

      document.getElementById("accept-cookies").onclick = function(){
        localStorage.setItem("ga_consent", "accepted");
        loadGA();
        banner.style.display = "none";
        adjustLayout();
      };

      document.getElementById("reject-cookies").onclick = function(){
        localStorage.setItem("ga_consent", "rejected");
        banner.style.display = "none";
        adjustLayout();
      };

    })();
  </script>

</body>
</html>

<style>
:root {
  --bg-main: #061630;
  --bg-card: #0c213f;
  --primary: #e10600;
  --text-main: #ffffff;
  --text-muted: #9aa4b2;
  --radius: 14px;
  --shadow-card: 0 6px 18px rgba(0,0,0,0.35);
}

body {
  margin: 0;
  background: var(--bg-main);
  font-family: "Open Sans", sans-serif;
  color: var(--text-main);
}

.app-wrapper {
  max-width: 520px;
  margin: 0 auto;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 24px 18px 110px;
}

.cookie-banner {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 520px;
  background: var(--bg-card);
  padding: 16px;
  z-index: 200;
  box-shadow: 0 -4px 16px rgba(0,0,0,0.4);
}

body.banner-visible footer {
  bottom: 90px;
}

.page-transition {
  animation: fadeIn 0.25s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}
</style>
