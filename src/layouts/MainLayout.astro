---
import "../styles/global.css";
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";

const {
  title = "Airsoft Nation",
  description = "Comunidad, eventos y juego de airsoft.",
  image = "/logo_airsoft_nation.svg",
  noIndex = false,
  url = "https://tree.airsoftnation.eu"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <!-- Preload logo -->
    <link rel="preload" href="/logo_airsoft_nation.svg" as="image" type="image/svg+xml" />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Airsoft Nation",
        "url": "https://tree.airsoftnation.eu",
        "logo": "https://tree.airsoftnation.eu/logo_airsoft_nation.svg",
        "sameAs": [
          "https://www.instagram.com/airsoftnation.eu/"
        ]
      }
    </script>
  </head>

  <body>

    <Header />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Bottom Nav solo móvil -->
    <nav class="bottom-nav">
      <a href="/">Home</a>
      <a href="/saber/">Saber</a>
      <a href="/taller/">Taller</a>
      <a href="https://wa.me/34614212918" target="_blank" rel="noopener">
        WhatsApp
      </a>
      <a href="https://www.instagram.com/airsoftnation.eu/" target="_blank" rel="noopener">
        Instagram
      </a>
    </nav>

    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        background: #0b1220;
        color: white;
        line-height: 1.6;
      }

      main {
        padding-bottom: 80px;
      }

      /* Bottom nav móvil */
      .bottom-nav {
        position: fixed;
        bottom: 0;
        width: 100%;
        display: flex;
        justify-content: space-around;
        align-items: center;
        padding: 14px 0;
        background: rgba(17, 24, 39, 0.95);
        backdrop-filter: blur(8px);
        border-top: 1px solid rgba(255,255,255,0.08);
        font-size: 0.9rem;
        z-index: 1000;
      }

      .bottom-nav a {
        color: white;
        text-decoration: none;
        opacity: 0.8;
        transition: opacity 0.2s ease;
      }

      .bottom-nav a:hover {
        opacity: 1;
      }

      @media (min-width: 768px) {
        .bottom-nav {
          display: none;
        }

        main {
          padding-bottom: 0;
        }
      }
    </style>

  </body>
</html>

