---
import "../styles/global.css";

const {
  title = "Airsoft Nation",
  description = "Comunidad, eventos y juego de airsoft.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>

<body>

  <div class="app">

    <div class="app-content">
      <slot />
    </div>

    <nav class="bottom-nav">
      <a href="/">🏠</a>
      <a href="/saber/">📘</a>
      <a href="/taller/">🛠</a>
      <a href="https://wa.me/34614212918" target="_blank">💬</a>
      <a href="https://www.instagram.com/airsoftnation.eu/" target="_blank">📷</a>
    </nav>

    <div class="legal-bar">
      Derechos de autor © Registro marca de la Unión Europea nº 19040186 | Airsoft Nation
    </div>

  </div>

</body>
</html>
