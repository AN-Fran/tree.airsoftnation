---
const navItems = [
  { name: "Saber", href: "/saber" },
  { name: "Ir a jugar", href: "/ir-a-jugar" },
  { name: "Eventos", href: "/eventos" },
  { name: "Taller", href: "/taller" },
  { name: "Novedades", href: "/novedades" },
  { name: "Comprar", href: "/comprar" }
];
---

<header class="header">
  <div class="header-inner">
    
    <a href="/" class="logo">
      <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" />
    </a>

    <nav class="nav">
      {navItems.map(item => (
        <a href={item.href}>{item.name}</a>
      ))}
    </nav>

  </div>
</header>

<style>
.header {
  width: 100%;
  padding: 1.5rem 1rem;
  background: #0f172a; /* azul oscuro */
}

.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo img {
  height: 120px; /* controla tamaño del logo vertical */
  width: auto;
}

.nav {
  margin-top: 1.2rem;
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem;
  justify-content: center;
}

.nav a {
  text-decoration: none;
  color: #ffffff;
  font-weight: 500;
  font-size: 0.95rem;
  transition: opacity 0.2s ease;
}

.nav a:hover {
  opacity: 0.7;
}

/* Responsive */
@media (max-width: 640px) {
  .logo img {
    height: 90px;
  }

  .nav {
    gap: 1rem;
  }

  .nav a {
    font-size: 0.85rem;
  }
}
</style>
