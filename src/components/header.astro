---
import { Astro } from "astro";

const currentPath = Astro.url.pathname;

const navItems = [
  { name: "Saber", href: "/saber/" },
  { name: "Ir a jugar", href: "/ir-a-jugar/" },
  { name: "Eventos", href: "/eventos/" },
  { name: "Taller", href: "/taller/" },
  { name: "Novedades", href: "/novedades/" },
  { name: "Comprar", href: "/comprar/" }
];
---

<header class="header">
  <div class="container header-inner">

    <a href="/" class="logo">
      <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" />
    </a>

    <nav class="nav">
      {navItems.map(item => (
        <a
          href={item.href}
          class={currentPath === item.href ? "active" : ""}
        >
          {item.name}
        </a>
      ))}
    </nav>

  </div>
</header>

<style>
.header {
  position: sticky;
  top: 0;
  width: 100%;
  backdrop-filter: blur(10px);
  background: rgba(15, 23, 42, 0.85);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  z-index: 1000;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.header-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
}

.logo img {
  height: 110px;
  width: auto;
  transition: transform 0.2s ease;
}

.logo img:hover {
  transform: scale(1.03);
}

.nav {
  margin-top: 24px;
  display: flex;
  flex-wrap: wrap;
  gap: 28px;
  justify-content: center;
}

.nav a {
  text-decoration: none;
  color: #ffffff;
  font-weight: 500;
  font-size: 0.95rem;
  letter-spacing: 0.5px;
  opacity: 0.8;
  transition: opacity 0.2s ease, color 0.2s ease;
}

.nav a:hover {
  opacity: 1;
}

.nav a.active {
  opacity: 1;
  color: #00d4ff;
}

/* Desktop horizontal layout */
@media (min-width: 768px) {
  .header-inner {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  .nav {
    margin-top: 0;
  }

  .logo img {
    height: 90px;
  }
}

/* Mobile refinement */
@media (max-width: 480px) {
  .logo img {
    height: 80px;
  }

  .nav {
    gap: 16px;
  }

  .nav a {
    font-size: 0.85rem;
  }
}
</style>
