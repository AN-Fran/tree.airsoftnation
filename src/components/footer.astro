---
const year = new Date().getFullYear();
---

<footer class="footer">

  <div class="container footer-grid">

    <!-- Marca -->
    <div class="footer-brand">
      <img src="/logo_airsoft_nation.svg"
           alt="Airsoft Nation"
           width="160"
           height="50" />

      <p class="brand-text">
        Centro táctico especializado en HPA, comunidad activa y servicio técnico profesional.
      </p>

      <a href="https://maps.app.goo.gl/qZ9mKjF6iWpGxFBG7"
         target="_blank"
         rel="noopener"
         class="rating-badge">
        <span class="stars">★★★★★</span>
        <span class="rating-value">4.7 Google</span>
      </a>
    </div>

    <!-- Links -->
    <div class="footer-links">

      <div>
        <h4>Navegación</h4>
        <a href="/saber/">Saber</a>
        <a href="/eventos/">Eventos</a>
        <a href="/novedades/">Novedades</a>
      </div>

      <div>
        <h4>Servicios</h4>
        <a href="/hpa/">HPA</a>
        <a href="/taller/">Servicio técnico</a>
        <a href="/wolverine/">Wolverine</a>
      </div>

      <div>
        <h4>Contacto</h4>
        <a href="https://wa.me/34614212918" target="_blank">WhatsApp</a>
        <a href="https://www.instagram.com/airsoftnation.eu/" target="_blank">Instagram</a>
        <a href="mailto:admin@airsoftnation.eu">Email</a>
      </div>

    </div>

  </div>

  <div class="footer-bottom">
    <span>© {year} Airsoft Nation · Celrà (Girona)</span>
    <span>Marca UE nº 19040186</span>
  </div>

</footer>

<style>
.footer {
  background: #0b1220;
  border-top: 1px solid rgba(255,255,255,0.05);
  padding: 45px 20px 20px;
  margin-top: 40px;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
}

.footer-grid {
  display: grid;
  gap: 50px;
}

.footer-brand img {
  margin-bottom: 16px;
}

.brand-text {
  color: #9ca3af;
  font-size: 0.9rem;
  margin-bottom: 20px;
  max-width: 320px;
}

.rating-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 0.85rem;
  text-decoration: none;
  color: white;
  opacity: 0.9;
}

.stars {
  color: #ff3b2f;
  letter-spacing: 2px;
}

.footer-links {
  display: grid;
  gap: 30px;
}

.footer-links h4 {
  font-size: 0.8rem;
  text-transform: uppercase;
  color: #9ca3af;
  margin-bottom: 12px;
  letter-spacing: 1px;
}

.footer-links a {
  display: block;
  text-decoration: none;
  color: white;
  opacity: 0.85;
  font-size: 0.9rem;
  margin-bottom: 6px;
  transition: 0.2s ease;
}

.footer-links a:hover {
  color: #ff3b2f;
}

.footer-bottom {
  margin-top: 40px;
  padding-top: 15px;
  border-top: 1px solid rgba(255,255,255,0.05);
  font-size: 0.75rem;
  color: #9ca3af;
  display: flex;
  flex-direction: column;
  gap: 5px;
  text-align: center;
}

@media (min-width: 768px) {
  .footer-grid {
    grid-template-columns: 1.2fr 2fr;
  }

  .footer-links {
    grid-template-columns: repeat(3, 1fr);
  }

  .footer-bottom {
    flex-direction: row;
    justify-content: space-between;
  }
}
</style>
