---
import { Astro } from "astro";

const currentPath = Astro.url.pathname;

const items = [
  { href: "/", icon: "bi-house", label: "Inicio" },
  { href: "/comprar/", icon: "bi-bag", label: "Comprar" },
  { href: "/eventos/", icon: "bi-trophy", label: "Eventos" },
  { href: "/hpa/", icon: "bi-tools", label: "HPA" },
  { href: "https://www.instagram.com/airsoftnation.eu/", icon: "bi-instagram", label: "IG", external: true }
];
---

<nav class="bottom-nav">

  {items.map(item => {
    const isActive =
      !item.external &&
      (item.href === "/"
        ? currentPath === "/"
        : currentPath.startsWith(item.href));

    return (
      <a
        href={item.href}
        class={`nav-item ${isActive ? "active" : ""}`}
        target={item.external ? "_blank" : undefined}
        rel={item.external ? "noopener" : undefined}
      >
        <i class={`bi ${item.icon}`}></i>
        <span>{item.label}</span>
      </a>
    );
  })}

</nav>

<style>
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);

  width: 100%;
  max-width: 520px;

  background: var(--bg-card);
  display: flex;
  justify-content: space-around;
  align-items: center;

  padding: 8px 0 calc(10px + env(safe-area-inset-bottom));
  box-shadow: 0 -4px 14px rgba(0,0,0,0.35);

  z-index: 100;
}

.nav-item {
  flex: 1;
  text-align: center;
  text-decoration: none;
  color: var(--text-muted);

  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;

  font-size: 0.65rem;
  font-weight: 500;
}

.nav-item i {
  font-size: 1.15rem;
  transition: transform 0.15s ease;
}

.nav-item.active {
  color: var(--primary);
}

.nav-item.active i {
  transform: scale(1.05);
}
</style>
