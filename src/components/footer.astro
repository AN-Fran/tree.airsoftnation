---
const year = new Date().getFullYear();
---

<footer class="footer">

  <div class="footer-inner">

    <!-- Marca -->
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation">
      </a>

      <p>
        Centro táctico especializado en HPA y servicio técnico profesional.
      </p>

      <div class="footer-social">
        <a href="https://wa.me/34614212918" target="_blank" aria-label="WhatsApp">
          <svg viewBox="0 0 24 24">
            <path d="M12 2a10 10 0 0 0-8.5 15l-1 5 5-1A10 10 0 1 0 12 2z"/>
          </svg>
        </a>

        <a href="https://www.instagram.com/airsoftnation.eu/" target="_blank" aria-label="Instagram">
          <svg viewBox="0 0 24 24">
            <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5z"/>
          </svg>
        </a>

        <a href="/" aria-label="Home">
          <svg viewBox="0 0 24 24">
            <path d="M3 11l9-8 9 8v9a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Links -->
    <div class="footer-links">

      <div>
        <h4>Navegación</h4>
        <a href="/saber/">Saber</a>
        <a href="/eventos/">Eventos</a>
        <a href="/novedades/">Novedades</a>
      </div>

      <div>
        <h4>Servicios</h4>
        <a href="/hpa/">HPA</a>
        <a href="/taller/">Servicio técnico</a>
        <a href="/wolverine/">Wolverine</a>
      </div>

    </div>

  </div>

  <div class="footer-bottom">
    <span>© {year} Airsoft Nation · Celrà (Girona)</span>
    <span>Marca UE nº 19040186</span>
  </div>

</footer>

<style>
.footer {
  background: #0b1220;
  border-top: 1px solid rgba(255,255,255,0.05);
  padding: 50px 20px 25px;
  margin-top: 80px;
}

.footer-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  gap: 40px;
}

.footer-logo img {
  height: 40px;
  margin-bottom: 12px;
}

.footer-brand p {
  font-size: 0.9rem;
  opacity: 0.7;
  max-width: 320px;
  margin-bottom: 20px;
}

.footer-social {
  display: flex;
  gap: 18px;
}

.footer-social svg {
  width: 22px;
  height: 22px;
  fill: #E02B20;
  transition: 0.2s ease;
}

.footer-social svg:hover {
  transform: translateY(-3px);
}

.footer-links {
  display: grid;
  gap: 30px;
}

.footer-links h4 {
  font-size: 0.75rem;
  text-transform: uppercase;
  opacity: 0.6;
  margin-bottom: 10px;
}

.footer-links a {
  display: block;
  text-decoration: none;
  color: white;
  font-size: 0.9rem;
  margin-bottom: 6px;
  opacity: 0.85;
}

.footer-links a:hover {
  color: #ff3b2f;
}

.footer-bottom {
  max-width: 1100px;
  margin: 40px auto 0;
  padding-top: 15px;
  border-top: 1px solid rgba(255,255,255,0.05);
  font-size: 0.75rem;
  color: #9ca3af;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
}

@media (min-width: 768px) {
  .footer-inner {
    grid-template-columns: 1fr 1fr;
  }

  .footer-links {
    grid-template-columns: repeat(2, 1fr);
  }
}

</style>
