---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" />
      <p>
        Comunidad, eventos y equipamiento especializado en airsoft.
      </p>
    </div>

    <div class="footer-links">
      <div>
        <h4>Explorar</h4>
        <a href="/saber/">Saber</a>
        <a href="/ir-a-jugar/">Ir a jugar</a>
        <a href="/eventos/">Eventos</a>
        <a href="/taller/">Taller</a>
      </div>

      <div>
        <h4>Actualidad</h4>
        <a href="/novedades/">Novedades</a>
        <a href="/comprar/">Comprar</a>
      </div>

      <div>
        <h4>Contacto</h4>
        <a href="https://wa.me/34614212918" target="_blank" rel="noopener">
          WhatsApp
        </a>
        <a href="https://www.instagram.com/airsoftnation.eu/" target="_blank" rel="noopener">
          Instagram
        </a>
        <a href="mailto:admin@airsoftnation.eu">
          Email
        </a>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <span>© {year} Airsoft Nation</span>
    <span>Todos los derechos reservados</span>
  </div>
</footer>

<style>
.footer {
  background: #0f172a;
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 80px 20px 40px;
  margin-top: 120px;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
}

.footer-inner {
  display: grid;
  gap: 60px;
}

.footer-brand img {
  height: 90px;
  margin-bottom: 20px;
}

.footer-brand p {
  color: #9ca3af;
  max-width: 320px;
}

.footer-links {
  display: grid;
  gap: 40px;
}

.footer-links h4 {
  margin-bottom: 14px;
  font-size: 0.95rem;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: #9ca3af;
}

.footer-links a {
  display: block;
  margin-bottom: 8px;
  text-decoration: none;
  color: white;
  opacity: 0.8;
  transition: opacity 0.2s ease;
}

.footer-links a:hover {
  opacity: 1;
}

.footer-bottom {
  margin-top: 60px;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.06);
  display: flex;
  flex-direction: column;
  gap: 8px;
  font-size: 0.85rem;
  color: #9ca3af;
  text-align: center;
}

/* Desktop */
@media (min-width: 768px) {
  .footer-inner {
    grid-template-columns: 1.5fr 2fr;
  }

  .footer-links {
    grid-template-columns: repeat(3, 1fr);
  }

  .footer-bottom {
    flex-direction: row;
    justify-content: space-between;
  }
}
</style>
