<footer class="mobile-nav">

  <a href="/" class="nav-item">
    <i class="bi bi-house"></i>
  </a>

  <a href="/comprar/" class="nav-item">
    <i class="bi bi-bag"></i>
  </a>

  <a href="/hpa/" class="nav-item">
    <i class="bi bi-tools"></i>
  </a>

  <a href="/eventos/" class="nav-item">
    <i class="bi bi-calendar-event"></i>
  </a>

  <a href="/contacto-form/" class="nav-item">
    <i class="bi bi-chat-dots"></i>
  </a>

</footer>

<style>
.mobile-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;

  height: 60px;
  background: #0b1220;
  border-top: 1px solid rgba(255,255,255,0.08);

  display: flex;
  justify-content: space-around;
  align-items: center;

  z-index: 1000;
}

.nav-item {
  color: rgba(255,255,255,0.6);
  font-size: 22px;
  text-decoration: none;
  transition: 0.2s ease;
}

.nav-item:hover,
.nav-item.active {
  color: #E02B20;
}
</style>
