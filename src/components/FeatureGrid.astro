---
const { items = [] } = Astro.props;
---

<section class="features">
  <div class="container grid">
    {items.map(item => (
      <div class="card">
        <h3>{item.title}</h3>
        <p>{item.text}</p>
      </div>
    ))}
  </div>
</section>

<style>
.features {
  padding: 120px 20px;
}

.grid {
  display: grid;
  gap: 30px;
}

.card {
  padding: 30px;
  border-radius: 12px;
  background: #111827;
  border: 1px solid rgba(255,255,255,0.06);
}

h3 {
  margin-bottom: 16px;
}

p {
  color: #9ca3af;
}

@media (min-width: 768px) {
  .grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>
