---
const now = new Date();

// Forzar zona horaria España
const madridTime = new Date(
  now.toLocaleString("en-US", { timeZone: "Europe/Madrid" })
);

const day = madridTime.getDay(); // 0 = Domingo
const hour = madridTime.getHours();
const minutes = madridTime.getMinutes();
const todayStr = madridTime.toISOString().split("T")[0];

// Festivos nacionales España (añadir cada año)
const nationalHolidays = [
  "2026-01-01",
  "2026-01-06",
  "2026-05-01",
  "2026-08-15",
  "2026-10-12",
  "2026-11-01",
  "2026-12-06",
  "2026-12-08",
  "2026-12-25"
];

const isHoliday = nationalHolidays.includes(todayStr);

// Horario
const schedule = {
  1: { morning: [11, 14], afternoon: [16, 20] }, // Lunes
  2: { morning: [11, 14], afternoon: [16, 20] },
  3: { morning: [11, 14], afternoon: [16, 20] },
  4: { morning: [11, 14], afternoon: [16, 20] },
  5: { morning: [11, 14], afternoon: [16, 21] }, // Viernes
  6: null, // Sábado cerrado
  0: null  // Domingo cerrado
};

let isOpen = false;
let message = "";

if (isHoliday) {
  message = "Cerrado · Festivo nacional";
} else {
  const todaySchedule = schedule[day];

  if (todaySchedule) {
    const current = hour + minutes / 60;

    const [mOpen, mClose] = todaySchedule.morning;
    const [aOpen, aClose] = todaySchedule.afternoon;

    if (
      (current >= mOpen && current < mClose) ||
      (current >= aOpen && current < aClose)
    ) {
      isOpen = true;
      message = `Abierto ahora`;
    } else {
      message = `Cerrado · Horario 11-14 / 16-${day === 5 ? "21" : "20"}`;
    }
  } else {
    message = "Cerrado hoy";
  }
}
---

<section class="hero">

  <img 
    src="/logo_airsoft_nation.svg" 
    alt="Airsoft Nation"
    class="logo"
  />

  <p class="tagline">
    Comunidad, juego y evolución táctica
  </p>

  <div class={`store-status ${isOpen ? "open" : "closed"}`}>
    {isOpen ? "🟢" : "🔴"} {message}
  </div>

</section>

<style>
.hero {
  text-align: center;
  padding: 60px 20px 40px;
}

.logo {
  width: 260px;
  max-width: 85%;
  filter:
    brightness(1.25)
    contrast(1.1)
    drop-shadow(0 0 20px rgba(0,180,255,0.35))
    drop-shadow(0 10px 40px rgba(0,0,0,0.6));
  animation: fadeIn 0.8s ease forwards;
  opacity: 0;
}

.tagline {
  margin-top: 18px;
  font-size: 0.95rem;
  opacity: 0.75;
  letter-spacing: 0.5px;
  animation: fadeIn 1.2s ease forwards;
  opacity: 0;
}

.store-status {
  margin-top: 14px;
  font-size: 0.9rem;
  font-weight: 500;
  animation: fadeIn 1.4s ease forwards;
  opacity: 0;
}

.store-status.open {
  color: #22c55e;
}

.store-status.closed {
  color: #ef4444;
}

@keyframes fadeIn {
  to { opacity: 1; }
}
</style>
