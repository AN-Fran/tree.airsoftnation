---
const {
  title = "Airsoft Nation",
  subtitle = "Comunidad, juego y evolución táctica",
  primaryCTA = { label: "Ir a jugar", href: "/ir-a-jugar/" }
} = Astro.props;
---

<section class="hero">
  <img src="/logo_airsoft_nation.svg" alt="Airsoft Nation" class="logo" />

  <h1>{title}</h1>
  <p>{subtitle}</p>

  <a href={primaryCTA.href} class="cta">
    {primaryCTA.label}
  </a>
</section>

<style>
.hero {
  padding: 60px 20px 40px;
  text-align: center;
  animation: fadeIn 0.8s ease forwards;
}

.logo {
  width: 110px;
  margin-bottom: 24px;
  animation: float 4s ease-in-out infinite;
}

h1 {
  font-size: 1.8rem;
  margin-bottom: 10px;
  font-weight: 600;
}

p {
  font-size: 0.95rem;
  opacity: 0.7;
  margin-bottom: 28px;
}

.cta {
  display: inline-block;
  padding: 14px 28px;
  background: linear-gradient(135deg, #00b894, #0984e3);
  border-radius: 999px;
  color: white;
  text-decoration: none;
  font-weight: 600;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.cta:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.4);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}
</style>
