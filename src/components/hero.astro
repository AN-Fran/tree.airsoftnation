---
const {
  title,
  subtitle = "",
  primaryText = "",
  primaryHref = "#",
  background = ""
} = Astro.props;
---

<section class="hero" style={background ? `background-image: url(${background})` : ""}>
  <div class="overlay"></div>

  <div class="container hero-inner">
    <h1>{title}</h1>

    {subtitle && <p class="subtitle">{subtitle}</p>}

    {primaryText && (
      <a href={primaryHref} class="btn">
        {primaryText}
      </a>
    )}
  </div>
</section>

<style>
.hero {
  position: relative;
  padding: 160px 20px 180px;
  text-align: center;
  background-size: cover;
  background-position: center;
  background-color: #0b1220;
}

.overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(11,18,32,0.8),
    rgba(11,18,32,0.95)
  );
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 800px;
  margin: 0 auto;
}

h1 {
  font-size: 2.8rem;
  margin-bottom: 24px;
}

.subtitle {
  color: #9ca3af;
  margin-bottom: 40px;
}

.btn {
  display: inline-block;
  padding: 14px 28px;
  border-radius: 8px;
  text-decoration: none;
  background: #00d4ff;
  color: black;
  font-weight: 600;
  transition: opacity 0.2s ease;
}

.btn:hover {
  opacity: 0.85;
}

@media (min-width: 768px) {
  h1 {
    font-size: 3.4rem;
  }
}
</style>
